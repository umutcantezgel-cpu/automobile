interface TeamMember {
  initials: string;
  name: string;
  role: string;
  gradient: string;
}

const KEY_TEAM: TeamMember[] = [
  { initials: 'CA', name: 'Carla Apex', role: 'Geschäftsführerin', gradient: 'from-primary/90 to-accent/60' },
