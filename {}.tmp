          <div className="adm-card-body flex flex-col gap-1">
            {LEADS.map((lead) => (
              <div
                key={lead.name}
                className="flex items-center gap-3 rounded-lg p-3 transition-colors"
                style={{ cursor: 'pointer' }}
                onMouseEnter={(e) => {
                  (e.currentTarget as HTMLDivElement).style.background = 'var(--color-muted)';
                }}
                onMouseLeave={(e) => {
                  (e.currentTarget as HTMLDivElement).style.background = 'transparent';
                }}
              >
                <div
                  className="flex items-center justify-center shrink-0"
                  style={{
                    width: 'calc(var(--space-1) * 9)',
                    height: 'calc(var(--space-1) * 9)',
                    borderRadius: 'calc(var(--space-1) * 2.25)',
                    background: lead.color,
                    color: 'white',
                    fontSize: 11,
                    fontWeight: 700,
                    fontFamily: 'var(--font-display)',
                  }}
                >
                  {lead.initials}
                </div>
                <div className="flex-1 min-w-0">
                  <div className="text-[length:var(--t-sm)] font-medium truncate">{lead.name}</div>
                  <div 
                    className="text-[length:var(--t-xs)] truncate text-muted-foreground"
                  >
                    {lead.vehicle}
                  </div>
                </div>
                <span
                  className="text-[length:var(--t-xs)] font-mono tabular-nums whitespace-nowrap text-muted-foreground"
                >
                  {lead.time}
                </span>
              </div>
            ))}
          </div>
        </motion.div>
      </div>
    </div>
  );
}
import type { Metadata } from 'next';
