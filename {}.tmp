/* ================================================================== */
/*  ANIMATION VARIANTS                                                 */
/* ================================================================== */

const fadeUp = {
  hidden: { opacity: 0, y: 24 },
  visible: (i: number) => ({
    opacity: 1,
    y: 0,
    transition: { delay: i * 0.08, duration: 0.5, ease: [0.25, 0.46, 0.45, 0.94] as const },
  }),
};

const staggerContainer = {
  hidden: {},
  visible: { transition: { staggerChildren: 0.06 } },
};

/* ================================================================== */
/*  COLLAPSIBLE MODULE COMPONENT                                       */
/* ================================================================== */

function ModuleSection({ module, defaultOpen }: { module: Module; defaultOpen: boolean }) {
  const [open, setOpen] = useState(defaultOpen);

  return (
    <div className="border-t border-border">
      <button
        onClick={() => setOpen((p) => !p)}
        className="flex items-center justify-between w-full py-4 px-1 text-left cursor-pointer group min-h-[var(--space-10)]"
        aria-expanded={open}
      >
        <span className="flex items-center gap-2.5 font-semibold text-sm">
          <span className="text-muted-foreground group-hover:text-primary transition-colors">{module.icon}</span>
          {module.title}
        </span>
        <motion.span
          animate={{ rotate: open ? 180 : 0 }}
          transition={{ duration: 0.25 }}
          className="text-muted-foreground"
        >
          <ChevronDown className="w-4 h-4" />
        </motion.span>
      </button>
      <AnimatePresence initial={false}>
        {open && (
          <motion.div
            initial={{ height: 0, opacity: 0 }}
            animate={{ height: 'auto', opacity: 1 }}
            exit={{ height: 0, opacity: 0 }}
            transition={{ duration: 0.3, ease: [0.25, 0.46, 0.45, 0.94] as const }}
            className="overflow-hidden"
          >
            <ul className="pb-4 px-1 space-y-2">
              {module.items.map((item) => (
                <li key={item.label} className="flex items-start gap-2.5 text-sm">
                  {item.included ? (
                    <Check className="w-4 h-4 text-success shrink-0 mt-0.5" />
                  ) : (
                    <X className="w-4 h-4 text-muted-foreground/40 shrink-0 mt-0.5" />
                  )}
                  <span className={cn(!item.included && 'text-muted-foreground/50 line-through')}>
                    {item.label}
                    {item.detail && (
                      <span className="text-muted-foreground text-xs ml-1.5">({item.detail})</span>
                    )}
                  </span>
                </li>
              ))}
            </ul>
          </motion.div>
        )}
      </AnimatePresence>
    </div>
  );
}

/* ================================================================== */
/*  FAQ ITEM COMPONENT                                                 */
/* ================================================================== */

function FAQItemComponent({ item, index }: { item: FAQItem; index: number }) {
  const [open, setOpen] = useState(false);

  return (
    <motion.div
      custom={index}
      variants={fadeUp}
      initial="hidden"
      whileInView="visible"
      viewport={{ once: true, margin: '-5%' }}
      className="border-b border-border"
    >
      <button
        onClick={() => setOpen((p) => !p)}
        className="flex items-center justify-between w-full py-5 text-left cursor-pointer group min-h-[var(--space-10)]"
        aria-expanded={open}
      >
        <span className="text-h4 pr-4 group-hover:text-primary transition-colors">{item.question}</span>
        <motion.span
          animate={{ rotate: open ? 180 : 0 }}
          transition={{ duration: 0.25 }}
          className="text-muted-foreground shrink-0"
        >
          <ChevronDown className="w-5 h-5" />
        </motion.span>
      </button>
      <AnimatePresence initial={false}>
        {open && (
          <motion.div
            initial={{ height: 0, opacity: 0 }}
            animate={{ height: 'auto', opacity: 1 }}
            exit={{ height: 0, opacity: 0 }}
            transition={{ duration: 0.3, ease: [0.25, 0.46, 0.45, 0.94] as const }}
            className="overflow-hidden"
          >
            <p className="pb-5 text-muted-foreground leading-relaxed max-w-prose">{item.answer}</p>
          </motion.div>
        )}
      </AnimatePresence>
    </motion.div>
  );
}

/* ================================================================== */
/*  COMPARISON CELL                                                    */
/* ================================================================== */

function ComparisonCell({ value }: { value: string | boolean }) {
  if (value === true) return <Check className="w-4 h-4 text-success mx-auto" />;
  if (value === false) return <Minus className="w-4 h-4 text-muted-foreground/30 mx-auto" />;
  return <span className="font-mono text-xs tabular-nums">{value}</span>;
}

/* ================================================================== */
/*  PAGE COMPONENT                                                     */
/* ================================================================== */

export default function PreisePage() {
  const [expandedTier, setExpandedTier] = useState<string>('growth');
  const tierRefs = useRef<Record<string, HTMLDivElement | null>>({});

  const scrollToTier = useCallback((id: string) => {
    setExpandedTier(id);
    const el = tierRefs.current[id];
    if (el) {
      el.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  }, []);

  return (
    <div className="min-h-screen">
      {/* ============================================================ */}
      {/*  HERO                                                         */}
      {/* ============================================================ */}
      <section className="section-y bg-background relative overflow-hidden">
        <div className="absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,color-mix(in_srgb,var(--color-primary)_6%,transparent),transparent)]" />
        <div className="container-x relative">
          <motion.div
            initial={{ opacity: 0, y: 20 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.6 }}
            className="max-w-4xl mx-auto text-center"
          >
            <p className="eyebrow mb-6">// Investition · transparent kalkuliert</p>
            <h1 className="text-h1 mb-6">
              Drei Stufen. Keine versteckten Kosten.
              <br />
              <span className="text-primary">Ehrlich kalkuliert.</span>
            </h1>
            <p className="text-body-lg text-muted-foreground max-w-2xl mx-auto">
              Eine Website ist eine Investition — keine laufende Verpflichtung.
              Sie sehen vor der Beauftragung, was Sie bekommen.
            </p>
          </motion.div>

          {/* Stats strip */}
          <motion.div
            variants={staggerContainer}
            initial="hidden"
            animate="visible"
            className="grid grid-cols-2 md:grid-cols-4 gap-4 mt-12 max-w-3xl mx-auto"
          >
            {HERO_STATS.map((stat, i) => (
              <motion.div
                key={stat.value}
                custom={i}
                variants={fadeUp}
                className="flex flex-col items-center gap-2 p-4 rounded-xl bg-card border border-border shadow-card"
              >
                <span className="text-primary">{stat.icon}</span>
                <span className="font-display font-semibold text-sm">{stat.value}</span>
                <span className="text-xs text-muted-foreground text-center">{stat.label}</span>
              </motion.div>
            ))}
          </motion.div>
        </div>
      </section>

      {/* ============================================================ */}
      {/*  QUICK DECISION HELPER                                        */}
      {/* ============================================================ */}
      <section className="pb-16 bg-background">
        <div className="container-x">
          <motion.div
            variants={staggerContainer}
            initial="hidden"
            whileInView="visible"
            viewport={{ once: true }}
            className="grid md:grid-cols-3 gap-4 max-w-4xl mx-auto"
          >
            {DECISION_HELPERS.map((helper, i) => (
              <motion.button
                key={helper.id}
                custom={i}
                variants={fadeUp}
                onClick={() => scrollToTier(helper.id)}
                className={cn(
                  'flex flex-col items-start gap-3 p-6 rounded-xl border text-left cursor-pointer',
                  'transition-all duration-300 group min-h-[var(--space-10)]',
                  helper.id === 'growth'
                    ? 'border-premium/30 bg-card shadow-card hover:shadow-glow-premium'
                    : 'border-border bg-card shadow-card hover:shadow-card-hover hover:-translate-y-1'
                )}
              >
                <span className={cn(
                  'p-2.5 rounded-lg',
                  helper.id === 'growth' ? 'bg-premium/10 text-premium' : 'bg-muted text-muted-foreground'
                )}>
                  {helper.icon}
                </span>
                <div>
                  <p className="font-display font-semibold text-base mb-0.5">{helper.title}</p>
                  <p className="text-sm text-muted-foreground">{helper.subtitle}</p>
                </div>
                <p className="text-xs text-muted-foreground/70 mt-auto">{helper.ideal}</p>
                <span className="flex items-center gap-1 text-xs font-semibold text-primary group-hover:gap-2 transition-all">
                  Details ansehen <ChevronRight className="w-3 h-3" />
                </span>
              </motion.button>
            ))}
          </motion.div>
        </div>
      </section>

      {/* ============================================================ */}
      {/*  PRICING TIERS                                                */}
      {/* ============================================================ */}
      <section className="section-y bg-card-elevated/30">
        <div className="container-x">
          <motion.div
            initial={{ opacity: 0, y: 20 }}
            whileInView={{ opacity: 1, y: 0 }}
            viewport={{ once: true }}
            transition={{ duration: 0.5 }}
            className="text-center mb-12"
          >
            <p className="eyebrow mb-4">// Leistungspakete</p>
            <h2 className="text-h2">Wählen Sie Ihre Stufe</h2>
          </motion.div>

          <div className="space-y-6 max-w-4xl mx-auto">
            {TIERS.map((tier, i) => {
              const isExpanded = expandedTier === tier.id;
              return (
                <motion.div
                  key={tier.id}
                  ref={(el) => {
                    tierRefs.current[tier.id] = el;
                  }}
                  custom={i}
                  variants={fadeUp}
                  initial="hidden"
                  whileInView="visible"
                  viewport={{ once: true }}
                  className={cn(
                    'rounded-2xl border bg-card overflow-hidden scroll-mt-24',
                    tier.featured
                      ? 'card-top-listing'
                      : 'border-border shadow-card'
                  )}
                >
                  {/* Tier header */}
                  <button
                    onClick={() => setExpandedTier(isExpanded ? '' : tier.id)}
                    className="w-full p-6 md:p-8 text-left cursor-pointer group min-h-[var(--space-10)]"
                    aria-expanded={isExpanded}
                  >
                    <div className="flex flex-col md:flex-row md:items-center justify-between gap-4">
                      <div className="flex-1">
                        <div className="flex items-center gap-3 mb-3">
                          {tier.featured ? (
                            <span className="badge-top-listing">
                              <Sparkles className="w-3 h-3" />
                              {tier.badge}
                            </span>
                          ) : (
                            <Badge variant={tier.badgeVariant}>{tier.badge}</Badge>
                          )}
                        </div>
                        <h3 className="text-h3 mb-2">{tier.name}</h3>
                        <p className="text-sm text-muted-foreground max-w-lg">{tier.description}</p>
                      </div>
                      <div className="flex flex-col items-start md:items-end gap-2 shrink-0">
                        <p className="font-display font-bold text-2xl md:text-3xl font-mono tabular-nums">
                          {tier.priceRange}
                        </p>
                        <p className="text-xs text-muted-foreground">{tier.priceNote}</p>
                        <div className="flex items-center gap-3 mt-1">
                          <span className="flex items-center gap-1 text-xs text-muted-foreground">
                            <Clock className="w-3 h-3" /> {tier.timeline}
                          </span>
                          <span className="flex items-center gap-1 text-xs text-muted-foreground">
                            <RefreshCw className="w-3 h-3" /> {tier.iterations}
                          </span>
                          <span className="flex items-center gap-1 text-xs text-muted-foreground">
                            <Layers className="w-3 h-3" /> {tier.pages}
                          </span>
                        </div>
                      </div>
                    </div>
                    <div className="flex items-center gap-2 mt-4 text-xs font-semibold text-primary">
                      {isExpanded ? 'Module ausblenden' : 'Module anzeigen'}
                      <motion.span
                        animate={{ rotate: isExpanded ? 180 : 0 }}
                        transition={{ duration: 0.25 }}
                      >
                        <ChevronDown className="w-4 h-4" />
                      </motion.span>
                    </div>
                  </button>

                  {/* Expandable modules */}
                  <AnimatePresence initial={false}>
                    {isExpanded && (
                      <motion.div
                        initial={{ height: 0, opacity: 0 }}
                        animate={{ height: 'auto', opacity: 1 }}
                        exit={{ height: 0, opacity: 0 }}
                        transition={{ duration: 0.4, ease: [0.25, 0.46, 0.45, 0.94] as const }}
                        className="overflow-hidden"
                      >
                        <div className="px-6 md:px-8 pb-6 md:pb-8">
                          <div className="grid md:grid-cols-2 gap-x-8">
                            {tier.modules.map((mod, mi) => (
                              <ModuleSection key={mod.title} module={mod} defaultOpen={mi === 0} />
                            ))}
                          </div>
                          <div className="mt-6 pt-6 border-t border-border flex flex-col sm:flex-row gap-3">
                            <Button variant="primary" size="lg">
                              Angebot anfordern
                              <ArrowRight className="w-4 h-4 ml-1" />
                            </Button>
                            <Button variant="outline" size="lg">
                              Unverbindlich beraten lassen
                            </Button>
                          </div>
                        </div>
                      </motion.div>
                    )}
                  </AnimatePresence>
                </motion.div>
              );
            })}
          </div>
        </div>
      </section>

      {/* ============================================================ */}
      {/*  ADD-ONS                                                      */}
      {/* ============================================================ */}
      <section className="section-y bg-background">
        <div className="container-x">
          <motion.div
            initial={{ opacity: 0, y: 20 }}
            whileInView={{ opacity: 1, y: 0 }}
            viewport={{ once: true }}
            transition={{ duration: 0.5 }}
            className="text-center mb-12"
          >
            <p className="eyebrow mb-4">// Modulare Erweiterungen</p>
            <h2 className="text-h2 mb-4">Add-ons nach Bedarf</h2>
            <p className="text-muted-foreground max-w-xl mx-auto">
              Erweitern Sie Ihr Paket gezielt mit den Bausteinen, die Ihr Autohaus braucht.
            </p>
          </motion.div>

          <motion.div
            variants={staggerContainer}
            initial="hidden"
            whileInView="visible"
            viewport={{ once: true }}
            className="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-5xl mx-auto"
          >
            {ADDONS.map((addon, i) => (
              <motion.div
                key={addon.name}
                custom={i}
                variants={fadeUp}
                className="p-5 rounded-xl border border-border bg-card shadow-card hover:shadow-card-hover hover:-translate-y-1 transition-all duration-300"
                style={{ transitionTimingFunction: 'cubic-bezier(0.16, 1, 0.3, 1)' }}
              >
                <div className="flex items-start justify-between mb-3">
                  <span className="p-2 rounded-lg bg-muted text-muted-foreground">{addon.icon}</span>
                  <span className="font-mono text-xs font-semibold tabular-nums text-primary">{addon.price}</span>
                </div>
                <h4 className="font-display font-semibold text-sm mb-1">{addon.name}</h4>
                <p className="text-xs text-muted-foreground leading-relaxed">{addon.description}</p>
              </motion.div>
            ))}
          </motion.div>
        </div>
      </section>

      {/* ============================================================ */}
      {/*  PROCESS TIMELINE (Horizontal with connected dots)            */}
      {/* ============================================================ */}
      <section className="section-y bg-card-elevated/30">
        <div className="container-x">
          <motion.div
            initial={{ opacity: 0, y: 20 }}
            whileInView={{ opacity: 1, y: 0 }}
            viewport={{ once: true }}
            transition={{ duration: 0.5 }}
            className="text-center mb-16"
          >
            <p className="eyebrow mb-4">// Unser Prozess</p>
            <h2 className="text-h2 mb-4">Von der Idee zum Launch</h2>
            <p className="text-muted-foreground max-w-xl mx-auto">
              Transparenter Ablauf in 6 Phasen — Sie wissen immer, wo wir stehen.
            </p>
          </motion.div>

          {/* Horizontal timeline */}
          <div className="max-w-5xl mx-auto">
            {/* Desktop: horizontal */}
            <div className="hidden md:block relative">
              {/* Connecting line */}
              <div className="absolute top-6 left-[calc(100%/12)] right-[calc(100%/12)] h-px bg-border" />

              <div className="grid grid-cols-6 gap-4">
                {PROCESS_PHASES.map((phase, i) => (
                  <motion.div
                    key={phase.step}
                    initial={{ opacity: 0, y: 20 }}
                    whileInView={{ opacity: 1, y: 0 }}
                    viewport={{ once: true }}
                    transition={{ delay: i * 0.1, duration: 0.5, ease: [0.25, 0.46, 0.45, 0.94] as const }}
                    className="flex flex-col items-center text-center"
                  >
                    {/* Dot */}
                    <div className="relative z-10 mb-4">
                      <div className="w-12 h-12 rounded-full bg-card border-2 border-primary/20 flex items-center justify-center shadow-card">
                        <span className="text-primary">{phase.icon}</span>
                      </div>
                    </div>
                    <span className="font-mono text-[length:var(--t-2xs)] font-semibold uppercase tracking-widest text-primary tabular-nums mb-1">
                      Phase {phase.step}
                    </span>
                    <h4 className="font-display font-semibold text-sm mb-1.5">{phase.title}</h4>
                    <p className="text-xs text-muted-foreground leading-relaxed mb-2">{phase.description}</p>
                    <span className="inline-block font-mono text-[length:var(--t-2xs)] tabular-nums text-primary/70 bg-primary/5 px-2 py-0.5 rounded">
                      {phase.duration}
                    </span>
                  </motion.div>
                ))}
              </div>
            </div>

            {/* Mobile: vertical cards */}
            <div className="md:hidden space-y-4">
              {PROCESS_PHASES.map((phase, i) => (
                <motion.div
                  key={phase.step}
                  custom={i}
                  variants={fadeUp}
                  initial="hidden"
                  whileInView="visible"
                  viewport={{ once: true }}
                  className="relative p-5 rounded-xl border border-border bg-card"
                >
                  <div className="flex items-center gap-3 mb-3">
                    <span className="flex items-center justify-center w-10 h-10 rounded-lg bg-primary/10 text-primary">
                      {phase.icon}
                    </span>
                    <div>
                      <span className="font-mono text-[length:var(--t-2xs)] font-semibold uppercase tracking-widest text-muted-foreground tabular-nums">
                        Phase {phase.step}
                      </span>
                      <h4 className="font-display font-semibold text-base">{phase.title}</h4>
                    </div>
                  </div>
                  <p className="text-sm text-muted-foreground mb-2">{phase.description}</p>
                  <span className="inline-block font-mono text-xs tabular-nums text-primary/70 bg-primary/5 px-2 py-1 rounded">
                    {phase.duration}
                  </span>
                </motion.div>
              ))}
            </div>
          </div>
        </div>
      </section>

      {/* ============================================================ */}
      {/*  COST TRANSPARENCY                                            */}
      {/* ============================================================ */}
      <section className="section-y bg-background">
        <div className="container-x">
          <motion.div
            initial={{ opacity: 0, y: 20 }}
            whileInView={{ opacity: 1, y: 0 }}
            viewport={{ once: true }}
            transition={{ duration: 0.5 }}
            className="max-w-3xl mx-auto"
          >
            <p className="eyebrow mb-4">// Kostentransparenz</p>
            <h2 className="text-h2 mb-2">Wo fließt Ihr Geld hin?</h2>
            <p className="text-muted-foreground mb-8">
              Beispielhafte Aufteilung für ein{' '}
              <span className="font-mono text-sm tabular-nums font-semibold text-foreground">12.500 €</span>{' '}
              Local-Dominance-Projekt:
            </p>

            <div className="space-y-4">
              {COST_ITEMS.map((item, i) => (
                <motion.div
                  key={item.label}
                  initial={{ opacity: 0, x: -20 }}
                  whileInView={{ opacity: 1, x: 0 }}
                  viewport={{ once: true }}
                  transition={{ delay: i * 0.1, duration: 0.4 }}
                >
                  <div className="flex items-center justify-between mb-1.5">
                    <span className="text-sm font-medium">{item.label}</span>
                    <span className="font-mono text-sm tabular-nums font-semibold">
                      {new Intl.NumberFormat('de-DE').format(Math.round(12500 * item.percentage / 100))} €
                      <span className="text-muted-foreground font-normal ml-1.5">
                        (<span className="font-mono tabular-nums">{item.percentage}%</span>)
                      </span>
                    </span>
                  </div>
                  <div className="h-3 bg-muted rounded-full overflow-hidden">
                    <motion.div
                      className={cn('h-full rounded-full', item.color)}
                      initial={{ width: 0 }}
                      whileInView={{ width: `${item.percentage}%` }}
                      viewport={{ once: true }}
                      transition={{ delay: i * 0.1 + 0.2, duration: 0.6, ease: "easeOut" as const }}
                    />
                  </div>
                </motion.div>
              ))}
            </div>

            <div className="mt-6 p-4 rounded-xl bg-card border border-border shadow-card">
              <div className="flex items-center justify-between">
                <span className="font-semibold text-sm">Gesamt</span>
                <span className="font-mono text-lg tabular-nums font-bold">12.500 €</span>
              </div>
            </div>
          </motion.div>
        </div>
      </section>

      {/* ============================================================ */}
      {/*  COMPARISON MATRIX                                            */}
      {/* ============================================================ */}
      <section className="section-y bg-card-elevated/30">
        <div className="container-x">
          <motion.div
            initial={{ opacity: 0, y: 20 }}
            whileInView={{ opacity: 1, y: 0 }}
            viewport={{ once: true }}
            transition={{ duration: 0.5 }}
            className="text-center mb-12"
          >
            <p className="eyebrow mb-4">// Feature-Vergleich</p>
            <h2 className="text-h2 mb-4">Alle Features im Überblick</h2>
          </motion.div>

          <motion.div
            initial={{ opacity: 0 }}
            whileInView={{ opacity: 1 }}
            viewport={{ once: true }}
            transition={{ duration: 0.5 }}
            className="max-w-5xl mx-auto overflow-x-auto"
          >
            <table className="w-full text-sm min-w-[var(--layout-content-lg)]">
              <thead>
                <tr className="border-b-2 border-border">
                  <th className="text-left py-3 px-3 font-display font-semibold w-[40%]">Feature</th>
                  <th className="text-center py-3 px-3 font-display font-semibold">Essential</th>
                  <th className="text-center py-3 px-3 font-display font-semibold">
                    <span className="inline-flex items-center gap-1">
                      Local Dominance <Sparkles className="w-3 h-3 text-premium" />
                    </span>
                  </th>
                  <th className="text-center py-3 px-3 font-display font-semibold">Enterprise</th>
                </tr>
              </thead>
              <tbody>
                {(() => {
                  let lastCategory = '';
                  return COMPARISON_ROWS.map((row, i) => {
                    const showCategory = row.category !== lastCategory;
                    lastCategory = row.category;
                    return (
                      <tr key={`${row.category}-${row.feature}-${i}`}>
                        {showCategory ? (
                          <td
                            className="pt-6 pb-2 px-3 font-mono text-[length:var(--t-2xs)] font-semibold uppercase tracking-widest text-primary"
                            colSpan={4}
                          >
                            {row.category}
                          </td>
                        ) : null}
                        {!showCategory && (
                          <>
                            <td className="py-2.5 px-3 text-muted-foreground border-b border-border/50">
                              {row.feature}
                            </td>
                            <td className="py-2.5 px-3 text-center border-b border-border/50">
                              <ComparisonCell value={row.tier1} />
                            </td>
                            <td className="py-2.5 px-3 text-center border-b border-border/50 bg-premium/[0.03]">
                              <ComparisonCell value={row.tier2} />
                            </td>
                            <td className="py-2.5 px-3 text-center border-b border-border/50">
                              <ComparisonCell value={row.tier3} />
                            </td>
                          </>
                        )}
                      </tr>
                    );
                  });
                })()}
              </tbody>
            </table>
          </motion.div>
        </div>
      </section>

      {/* ============================================================ */}
      {/*  CASE STUDIES                                                 */}
      {/* ============================================================ */}
      <section className="section-y bg-background">
        <div className="container-x">
          <motion.div
            initial={{ opacity: 0, y: 20 }}
            whileInView={{ opacity: 1, y: 0 }}
            viewport={{ once: true }}
            transition={{ duration: 0.5 }}
            className="text-center mb-12"
          >
            <p className="eyebrow mb-4">// Ergebnisse</p>
            <h2 className="text-h2 mb-4">Was unsere Kunden erreicht haben</h2>
          </motion.div>

          <motion.div
            variants={staggerContainer}
            initial="hidden"
            whileInView="visible"
            viewport={{ once: true }}
            className="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto"
          >
            {CASE_STUDIES.map((study, i) => (
              <motion.div
                key={study.title}
                custom={i}
                variants={fadeUp}
                className="p-6 rounded-xl border border-border bg-card shadow-card hover:shadow-card-hover transition-shadow duration-300"
                style={{ transitionTimingFunction: 'cubic-bezier(0.16, 1, 0.3, 1)' }}
              >
                <Badge variant="outline" className="mb-4">{study.tier}</Badge>
                <h4 className="font-display font-semibold text-base mb-2">{study.title}</h4>
                <p className="text-sm text-muted-foreground mb-5">{study.description}</p>
                <div className="grid grid-cols-3 gap-2">
                  {study.stats.map((stat) => (
                    <div key={stat.label} className="text-center">
                      <p className="font-mono text-lg tabular-nums font-bold text-primary">{stat.value}</p>
                      <p className="text-[length:var(--t-2xs)] text-muted-foreground leading-tight mt-0.5">{stat.label}</p>
                    </div>
                  ))}
                </div>
              </motion.div>
            ))}
          </motion.div>
        </div>
      </section>

      {/* ============================================================ */}
      {/*  FAQ                                                          */}
      {/* ============================================================ */}
      <section className="section-y bg-card-elevated/30">
        <div className="container-x">
          <motion.div
            initial={{ opacity: 0, y: 20 }}
            whileInView={{ opacity: 1, y: 0 }}
            viewport={{ once: true }}
            transition={{ duration: 0.5 }}
            className="text-center mb-12"
          >
            <p className="eyebrow mb-4">// Häufige Fragen</p>
            <h2 className="text-h2">Alles Wichtige auf einen Blick</h2>
          </motion.div>

          <div className="max-w-3xl mx-auto">
            {FAQ_ITEMS.map((item, i) => (
              <FAQItemComponent key={item.question} item={item} index={i} />
            ))}
          </div>
        </div>
      </section>

      {/* ============================================================ */}
      {/*  CTA                                                          */}
      {/* ============================================================ */}
      <section className="section-y bg-background">
        <div className="container-x">
          <motion.div
            initial={{ opacity: 0, y: 20 }}
            whileInView={{ opacity: 1, y: 0 }}
            viewport={{ once: true }}
            transition={{ duration: 0.5 }}
            className="max-w-2xl mx-auto text-center"
          >
            <div className="p-8 md:p-12 rounded-2xl border border-primary/20 bg-gradient-to-br from-primary/[0.03] to-transparent shadow-card">
              <Calculator className="w-10 h-10 text-primary mx-auto mb-4" />
              <h2 className="text-h2 mb-4">
                Was kostet Sie Ihre aktuelle Website?
              </h2>
              <p className="text-muted-foreground mb-8 max-w-lg mx-auto">
                Berechnen Sie in 2 Minuten, wie viel Umsatz Ihnen jeden Monat durch
                eine nicht-optimierte Website entgeht.
              </p>
              <Link href="/calculator">
                <Button variant="primary" size="xl">
                  Umsatzverlust berechnen
                  <ArrowRight className="w-5 h-5 ml-1" />
                </Button>
              </Link>
            </div>
          </motion.div>
        </div>
      </section>
    </div>
  );
}
'use client';

import { useState, useMemo } from 'react';
import { motion, AnimatePresence } from 'framer-motion';
import { Check, Info, ArrowRight, ShieldCheck, Banknote, Car, Percent } from 'lucide-react';
import { cn } from '@/lib/cn';
import { formatPrice } from '@/lib/format';

type ModelType = 'klassisch' | '3-wege' | 'leasing';
type CreditRating = 'sehr-gut' | 'gut' | 'mittel';

const LAUFZEITEN = [24, 36, 48, 60, 72];
const ZINSEN: Record<CreditRating, number> = {
  'sehr-gut': 2.99,
  'gut': 3.99,
  'mittel': 5.99,
};

export default function FinancingPage() {
  const [vehicleValue, setVehicleValue] = useState<number>(85000);
  const [anzahlungPct, setAnzahlungPct] = useState<number>(20);
  const [laufzeit, setLaufzeit] = useState<number>(48);
  const [model, setModel] = useState<ModelType>('3-wege');
  const [schlussratePct, setSchlussratePct] = useState<number>(30);
  const [rating, setRating] = useState<CreditRating>('sehr-gut');

  const anzahlung = Math.round((vehicleValue * anzahlungPct) / 100);
  let schlussrate = 0;
  if (model === '3-wege') {
    schlussrate = Math.round((vehicleValue * schlussratePct) / 100);
  }

  const results = useMemo(() => {
    const netCredit = vehicleValue - anzahlung;
    const interestRate = ZINSEN[rating] / 100;
    const years = laufzeit / 12;

    let monthly = 0;
    let totalInterest = 0;
    let totalPaid = 0;

    if (model === 'klassisch') {
      const totalAmount = netCredit * (1 + interestRate * years);
      monthly = totalAmount / laufzeit;
      totalInterest = totalAmount - netCredit;
      totalPaid = totalAmount + anzahlung;
    } else if (model === '3-wege') {
      const financedAmount = netCredit - schlussrate;
      const totalAmount = financedAmount * (1 + interestRate * years) + schlussrate * (interestRate * years);
      monthly = totalAmount / laufzeit;
      totalInterest = totalAmount - financedAmount;
      totalPaid = totalAmount + anzahlung + schlussrate;
    } else if (model === 'leasing') {
      // Simplistic leasing calc
      const depreciation = vehicleValue * 0.15 * years;
      const baseMonthly = depreciation / laufzeit;
      const interestPortion = (vehicleValue * interestRate) / 12;
      monthly = baseMonthly + interestPortion - (anzahlung / laufzeit);
      if (monthly < 0) monthly = 0;
      totalInterest = interestPortion * laufzeit;
      totalPaid = monthly * laufzeit + anzahlung;
      schlussrate = 0; 
    }

    return {
      monthly: Math.round(monthly),
      totalInterest: Math.round(totalInterest),
      totalPaid: Math.round(totalPaid),
      netCredit,
    };
  }, [vehicleValue, anzahlung, laufzeit, model, schlussrate, rating]);

  const chartData = [
    { label: 'Anzahlung', value: anzahlung, color: 'var(--color-muted-foreground)' },
    { label: 'Raten', value: results.monthly * laufzeit, color: 'var(--color-primary)' },
    { label: 'Schlussrate', value: schlussrate, color: 'var(--color-accent)' },
  ].filter(d => d.value > 0);

  const totalChartValue = chartData.reduce((acc, curr) => acc + curr.value, 0);
  let currentAngle = 0;

  return (
    <main className="min-h-screen pt-32 pb-24">
      <section className="container-x">
        <motion.div
          className="mb-12 max-w-2xl"
          initial={{ opacity: 0, y: 20 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ duration: 0.5, ease: "easeOut" as const }}
        >
          <p className="font-mono text-sm font-semibold tracking-widest text-primary uppercase mb-4">// Finanzierung</p>
          <h1 className="font-display text-4xl sm:text-5xl font-semibold tracking-tight mb-4">
            Finanzierung berechnen
          </h1>
          <p className="text-lg text-muted-foreground">
            Planen Sie Ihren nächsten Fahrzeugkauf flexibel. Passen Sie die Konditionen individuell an Ihre Bedürfnisse an.
          </p>
        </motion.div>

        <div className="grid grid-cols-1 lg:grid-cols-[1.4fr_1fr] gap-12 lg:gap-16 items-start">
          {/* ---- Calculator Form ---- */}
          <motion.div
            className="flex flex-col gap-10"
            initial={{ opacity: 0, y: 20 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.5, delay: 0.1, ease: "easeOut" as const }}
          >
            {/* Models */}
            <div className="space-y-4">
              <h3 className="text-lg font-semibold flex items-center gap-2">
                <Banknote className="size-5 text-primary" />
                Finanzierungs-Modell
              </h3>
              <div className="grid grid-cols-1 sm:grid-cols-3 gap-4">
                {[
                  { id: 'klassisch', label: 'Klassisch', desc: 'Konstante Raten' },
                  { id: '3-wege', label: '3-Wege', desc: 'Flexible Rückgabe', badge: 'Empfohlen' },
                  { id: 'leasing', label: 'Leasing', desc: 'Nur Nutzung zahlen' }
                ].map((m) => (
                  <button
                    key={m.id}
                    onClick={() => setModel(m.id as ModelType)}
                    className={cn(
                      'relative flex flex-col items-start p-5 rounded-xl border text-left transition-all min-h-[var(--space-10)]',
                      model === m.id
                        ? 'border-primary bg-primary/5 ring-1 ring-primary/20'
                        : 'border-border bg-card hover:border-border-strong'
                    )}
                  >
                    {m.badge && (
                      <span className="absolute -top-2.5 right-3 bg-primary text-primary-foreground text-[length:var(--t-xs)] font-bold px-2 py-0.5 rounded-full uppercase tracking-wider">
                        {m.badge}
                      </span>
                    )}
                    <div className="flex items-center justify-between w-full mb-1">
                      <span className="font-semibold text-foreground">{m.label}</span>
                      <div className={cn('size-4 rounded-full border flex items-center justify-center', model === m.id ? 'border-primary' : 'border-muted-foreground/30')}>
                        {model === m.id && <div className="size-2 rounded-full bg-primary" />}
                      </div>
                    </div>
                    <span className="text-sm text-muted-foreground">{m.desc}</span>
                  </button>
                ))}
              </div>
            </div>

            {/* Values */}
            <div className="space-y-8 bg-card border border-border p-6 rounded-2xl">
              <div className="space-y-4">
                <div className="flex justify-between items-end">
                  <label className="text-sm font-semibold">Fahrzeugwert</label>
                  <span className="font-mono text-xl tabular-nums font-semibold text-primary">{formatPrice(vehicleValue)}</span>
                </div>
                <input
                  type="range"
                  min={10000}
                  max={300000}
                  step={1000}
                  value={vehicleValue}
                  onChange={(e) => setVehicleValue(Number(e.target.value))}
                  className="w-full accent-primary"
                />
                <div className="flex justify-between text-xs font-mono text-muted-foreground">
                  <span>10.000 €</span>
                  <span>300.000 €</span>
                </div>
              </div>

              <div className="space-y-4">
                <div className="flex justify-between items-end">
                  <label className="text-sm font-semibold">Anzahlung</label>
                  <div className="text-right">
                    <div className="font-mono text-xl tabular-nums font-semibold">{formatPrice(anzahlung)}</div>
                    <div className="text-xs text-muted-foreground font-mono">{anzahlungPct}%</div>
                  </div>
                </div>
                <input
                  type="range"
                  min={0}
                  max={50}
                  step={1}
                  value={anzahlungPct}
                  onChange={(e) => setAnzahlungPct(Number(e.target.value))}
                  className="w-full accent-primary"
                />
              </div>

              <AnimatePresence>
                {model === '3-wege' && (
                  <motion.div
                    initial={{ opacity: 0, height: 0 }}
                    animate={{ opacity: 1, height: 'auto' }}
                    exit={{ opacity: 0, height: 0 }}
                    className="space-y-4 overflow-hidden pt-4 border-t border-border"
                  >
                    <div className="flex justify-between items-end">
                      <label className="text-sm font-semibold flex items-center gap-2">
                        Schlussrate
                        <Info className="size-3.5 text-muted-foreground" />
                      </label>
                      <div className="text-right">
                        <div className="font-mono text-xl tabular-nums font-semibold">{formatPrice(schlussrate)}</div>
                        <div className="text-xs text-muted-foreground font-mono">{schlussratePct}%</div>
                      </div>
                    </div>
                    <input
                      type="range"
                      min={10}
                      max={60}
                      step={1}
                      value={schlussratePct}
                      onChange={(e) => setSchlussratePct(Number(e.target.value))}
                      className="w-full accent-primary"
                    />
                  </motion.div>
                )}
              </AnimatePresence>
            </div>

            {/* Laufzeit */}
            <div className="space-y-4">
              <h3 className="text-lg font-semibold">Laufzeit (Monate)</h3>
              <div className="flex flex-wrap gap-3">
                {LAUFZEITEN.map((l) => (
                  <button
                    key={l}
                    onClick={() => setLaufzeit(l)}
                    className={cn(
                      'flex-1 min-w-[var(--space-12)] h-12 rounded-xl border font-mono text-sm font-semibold transition-all min-h-[var(--space-10)]',
                      laufzeit === l
                        ? 'border-primary bg-primary text-primary-foreground shadow-glow-primary'
                        : 'border-border bg-card text-foreground hover:border-border-strong'
                    )}
                  >
                    {l}
                  </button>
                ))}
              </div>
            </div>

            {/* Bonität */}
            <div className="space-y-4">
              <h3 className="text-lg font-semibold flex items-center gap-2">
                <ShieldCheck className="size-5 text-primary" />
                Eigene Bonität einschätzen
              </h3>
              <div className="grid grid-cols-1 sm:grid-cols-3 gap-4">
                {[
                  { id: 'sehr-gut', label: 'Sehr gut', rate: ZINSEN['sehr-gut'] },
                  { id: 'gut', label: 'Gut', rate: ZINSEN['gut'] },
                  { id: 'mittel', label: 'Mittel', rate: ZINSEN['mittel'] }
                ].map((b) => (
                  <button
                    key={b.id}
                    onClick={() => setRating(b.id as CreditRating)}
                    className={cn(
                      'flex items-center justify-between p-4 rounded-xl border transition-all min-h-[var(--space-10)]',
                      rating === b.id
                        ? 'border-primary bg-primary/5 ring-1 ring-primary/20'
                        : 'border-border bg-card hover:border-border-strong'
                    )}
                  >
                    <span className="font-semibold text-sm">{b.label}</span>
                    <span className="font-mono text-xs text-muted-foreground">{b.rate}% p.a.</span>
                  </button>
                ))}
              </div>
            </div>
          </motion.div>

          {/* ---- Sticky Result Card ---- */}
          <motion.div
            className="sticky top-32"
            initial={{ opacity: 0, x: 20 }}
            animate={{ opacity: 1, x: 0 }}
            transition={{ duration: 0.5, delay: 0.2, ease: "easeOut" as const }}
          >
            <div className="rounded-2xl border border-border bg-card shadow-card overflow-hidden">
              <div className="bg-muted/30 p-8 text-center border-b border-border">
                <p className="text-sm font-semibold text-muted-foreground tracking-wide uppercase mb-2">Ihre monatliche Rate</p>
                <div className="flex items-baseline justify-center gap-1">
                  <span className="font-mono text-5xl font-bold tracking-tighter tabular-nums text-foreground">
                    {formatPrice(results.monthly).replace(' €', '')}
                  </span>
                  <span className="text-xl font-semibold text-muted-foreground">€</span>
                </div>
                <p className="text-xs text-muted-foreground mt-3 flex items-center justify-center gap-1.5">
                  <Percent className="size-3" />
                  Effektiver Jahreszins: <span className="font-mono font-medium text-foreground">{ZINSEN[rating]}%</span>
                </p>
              </div>

              <div className="p-8">
                {/* SVG Donut Chart */}
                <div className="flex justify-center mb-8 relative">
                  <svg width="200" height="200" viewBox="0 0 200 200" className="transform -rotate-90">
                    {chartData.map((d, i) => {
                      if (d.value === 0) return null;
                      const fraction = d.value / totalChartValue;
                      const strokeDasharray = `${fraction * 2 * Math.PI * 80} ${2 * Math.PI * 80}`;
                      const strokeDashoffset = `-${currentAngle * 2 * Math.PI * 80}`;
                      currentAngle += fraction;
                      return (
                        <circle
                          key={i}
                          cx="100"
                          cy="100"
                          r="80"
                          fill="transparent"
                          stroke={d.color}
                          strokeWidth="16"
                          strokeDasharray={strokeDasharray}
                          strokeDashoffset={strokeDashoffset}
                          className="transition-all duration-1000 ease-[cubic-bezier(0.16,1,0.3,1)]"
                          strokeLinecap="round"
                        />
                      );
                    })}
                  </svg>
                  <div className="absolute inset-0 flex flex-col items-center justify-center text-center">
                    <Car className="size-8 text-muted-foreground/30 mb-1" />
                    <span className="font-mono text-sm font-semibold">{laufzeit}</span>
                    <span className="text-[length:var(--t-xs)] text-muted-foreground uppercase tracking-widest">Monate</span>
                  </div>
                </div>

                <div className="space-y-3 mb-8">
                  <div className="flex justify-between text-sm py-2 border-b border-border/50">
                    <span className="text-muted-foreground flex items-center gap-2">
                      <div className="size-2 rounded-full bg-muted-foreground" />
                      Anzahlung
                    </span>
                    <span className="font-mono tabular-nums font-medium">{formatPrice(anzahlung)}</span>
                  </div>
                  <div className="flex justify-between text-sm py-2 border-b border-border/50">
                    <span className="text-muted-foreground flex items-center gap-2">
                      <div className="size-2 rounded-full bg-primary" />
                      Raten ({laufzeit}x)
                    </span>
                    <span className="font-mono tabular-nums font-medium">{formatPrice(results.monthly * laufzeit)}</span>
                  </div>
                  {model === '3-wege' && (
                    <div className="flex justify-between text-sm py-2 border-b border-border/50">
                      <span className="text-muted-foreground flex items-center gap-2">
                        <div className="size-2 rounded-full bg-accent" />
                        Schlussrate
                      </span>
                      <span className="font-mono tabular-nums font-medium">{formatPrice(schlussrate)}</span>
                    </div>
                  )}
                  <div className="flex justify-between text-sm py-2">
                    <span className="text-muted-foreground">Zinskosten gesamt</span>
                    <span className="font-mono tabular-nums font-medium">{formatPrice(results.totalInterest)}</span>
                  </div>
                </div>

                <button className="w-full flex min-h-[var(--space-10)] items-center justify-center gap-2 rounded-xl bg-primary px-4 py-3.5 text-sm font-semibold text-primary-foreground transition-all hover:opacity-90 active:scale-[0.98] shadow-glow-primary">
                  Angebot anfordern
                  <ArrowRight className="size-4" />
                </button>
              </div>
            </div>
          </motion.div>
        </div>

        {/* ---- Info Cards ---- */}
        <motion.div
          className="mt-24 grid grid-cols-1 md:grid-cols-3 gap-6"
          initial={{ opacity: 0, y: 20 }}
          whileInView={{ opacity: 1, y: 0 }}
          viewport={{ once: true, margin: "calc(var(--space-1) * -25)" }}
          transition={{ duration: 0.5 }}
        >
          {[
            {
              title: 'Klassische Finanzierung',
              desc: 'Gleichbleibende Raten über die gesamte Laufzeit. Am Ende gehört das Fahrzeug Ihnen.',
              pros: ['Planungssicherheit', 'Keine Kilometerbegrenzung', 'Fahrzeugeigentum am Ende']
            },
            {
              title: '3-Wege Finanzierung',
              desc: 'Niedrige monatliche Raten dank Schlussrate. Volle Flexibilität am Vertragsende.',
              pros: ['Niedrige Raten', 'Rückgabe möglich', 'Anschlussfinanzierung']
            },
            {
              title: 'Leasing',
              desc: 'Sie zahlen nur für die tatsächliche Nutzung. Ideal, um immer das neueste Modell zu fahren.',
              pros: ['Stets aktuelles Modell', 'Oft ohne Anzahlung', 'Kein Restwertrisiko']
            }
          ].map((card, i) => (
            <div key={i} className="rounded-2xl border border-border bg-card p-6">
              <h4 className="font-semibold text-lg mb-3">{card.title}</h4>
              <p className="text-sm text-muted-foreground mb-6 leading-relaxed">{card.desc}</p>
              <ul className="space-y-3">
                {card.pros.map((pro, j) => (
                  <li key={j} className="flex items-start gap-2.5 text-sm">
                    <div className="mt-0.5 rounded-full bg-primary/10 p-0.5 text-primary">
                      <Check className="size-3" />
                    </div>
                    {pro}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </motion.div>
      </section>
    </main>
  );
}
'use client';

import { useState, useMemo, useCallback } from 'react';
import Link from 'next/link';
import {
  ChevronRight,
  LayoutGrid,
  List,
  Map,
  ArrowUpDown,
  SlidersHorizontal,
  X,
} from 'lucide-react';
import { motion, AnimatePresence } from 'framer-motion';
import { cn } from '@/lib/cn';
import { VehicleCard } from '@/components/sections/vehicle-card';
import { FilterSidebar } from '@/components/sections/filter-sidebar';
import type { FilterValues } from '@/components/sections/filter-sidebar';
import { MapView } from '@/components/sections/map-view';
import type { Vehicle } from '@/types/inventory';

const DEFAULT_FILTERS: FilterValues = {
  brands: [],
  vehicleTypes: [],
  priceMin: 0,
  priceMax: 500000,
  kmMax: 200000,
  fuels: [],
  gears: [],
  powerMin: 0,
  powerMax: 1200,
  colors: [],
};

type ViewMode = 'grid' | 'list' | 'map';
type SortKey = 'relevanz' | 'preis-asc' | 'preis-desc' | 'km-asc' | 'jahr-desc';

interface FahrzeugeContentProps {
  vehicles: Vehicle[];
  totalCount: number;
  categoryLabel: string;
}

const SORT_OPTIONS: { value: SortKey; label: string }[] = [
  { value: 'relevanz', label: 'Relevanz' },
  { value: 'preis-asc', label: 'Preis aufsteigend' },
  { value: 'preis-desc', label: 'Preis absteigend' },
  { value: 'km-asc', label: 'Kilometerstand' },
  { value: 'jahr-desc', label: 'Neueste zuerst' },
];

const ITEMS_PER_PAGE = 12;

export function FahrzeugeContent({
  vehicles,
  totalCount,
  categoryLabel,
}: FahrzeugeContentProps) {
  const [viewMode, setViewMode] = useState<ViewMode>('grid');
  const [sortKey, setSortKey] = useState<SortKey>('relevanz');
  const [currentPage, setCurrentPage] = useState(1);
  const [mobileFilterOpen, setMobileFilterOpen] = useState(false);
  const [filters, setFilters] = useState<FilterValues>(DEFAULT_FILTERS);

  const handleFilterChange = useCallback((newFilters: FilterValues) => {
    setFilters(newFilters);
    setCurrentPage(1);
  }, []);

  const sorted = useMemo(() => {
    const copy = [...vehicles];
    switch (sortKey) {
      case 'preis-asc':
        return copy.sort((a, b) => a.price - b.price);
      case 'preis-desc':
        return copy.sort((a, b) => b.price - a.price);
      case 'km-asc':
        return copy.sort((a, b) => a.km - b.km);
      case 'jahr-desc':
        return copy.sort((a, b) => {
          const ya = parseInt(a.year.split('/')[1] ?? '0', 10);
          const yb = parseInt(b.year.split('/')[1] ?? '0', 10);
          return yb - ya;
        });
      default:
        // relevanz — premium first, then by price desc
        return copy.sort((a, b) => {
          if (a.isPremium !== b.isPremium) return a.isPremium ? -1 : 1;
          return b.price - a.price;
        });
    }
  }, [vehicles, sortKey]);

  const totalPages = Math.ceil(sorted.length / ITEMS_PER_PAGE);
  const paginated = sorted.slice(
    (currentPage - 1) * ITEMS_PER_PAGE,
    currentPage * ITEMS_PER_PAGE
  );

  return (
    <div className="container-x py-8">
      {/* Breadcrumb */}
      <nav aria-label="Breadcrumb" className="mb-6">
        <ol className="flex items-center gap-1.5 text-sm text-muted-foreground">
          <li>
            <Link
              href="/"
              className="hover:text-foreground transition-colors"
            >
              Apex Motors
            </Link>
          </li>
          <li>
            <ChevronRight size={14} className="opacity-50" />
          </li>
          <li>
            <span className="text-foreground font-medium">Fahrzeuge</span>
          </li>
        </ol>
      </nav>

      {/* Page header */}
      <div className="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-8">
        <div>
          <p className="eyebrow mb-2">Fahrzeugbestand</p>
          <h1 className="text-h1">
            {categoryLabel}
            <span className="text-muted-foreground font-normal text-[length:var(--t-xs)] ml-3 font-mono tabular-nums">
              ({sorted.length})
            </span>
          </h1>
        </div>

        {/* Controls */}
        <div className="flex items-center gap-3">
          {/* Mobile filter toggle */}
          <button
            type="button"
            onClick={() => setMobileFilterOpen(true)}
            className="btn btn-outline btn-sm lg:hidden"
          >
            <SlidersHorizontal size={16} />
            Filter
          </button>

          {/* Sort dropdown */}
          <div className="relative">
            <div className="flex items-center gap-2">
              <ArrowUpDown size={14} className="text-muted-foreground" />
              <select
                value={sortKey}
                onChange={(e) => {
                  setSortKey(e.target.value as SortKey);
                  setCurrentPage(1);
                }}
                className="select-field !h-9 !w-auto !pr-8 text-sm"
              >
                {SORT_OPTIONS.map((opt) => (
                  <option key={opt.value} value={opt.value}>
                    {opt.label}
                  </option>
                ))}
              </select>
            </div>
          </div>

          {/* View toggle */}
          <div className="flex items-center gap-0.5 p-1 bg-muted rounded-lg border border-border">
            {([
              { mode: 'grid' as const, icon: LayoutGrid, label: 'Rasteransicht' },
              { mode: 'list' as const, icon: List, label: 'Listenansicht' },
              { mode: 'map' as const, icon: Map, label: 'Kartenansicht' },
            ] as const).map(({ mode, icon: Icon, label }) => (
              <button
                key={mode}
                type="button"
                onClick={() => setViewMode(mode)}
                className={cn(
                  'w-9 h-9 flex items-center justify-center rounded-md transition-all duration-150',
                  'min-w-[var(--space-10)] min-h-[var(--space-10)]',
                  viewMode === mode
                    ? 'bg-foreground text-background shadow-sm'
                    : 'text-muted-foreground hover:text-foreground'
                )}
                aria-label={label}
                title={label}
              >
                <Icon size={16} />
              </button>
            ))}
          </div>
        </div>
      </div>

      {/* Main layout: sidebar + content */}
      <div className="flex gap-8">
        {/* Desktop sidebar */}
        <div className="hidden lg:block w-[var(--layout-sidebar-sm)] shrink-0">
          <FilterSidebar filters={filters} onChange={handleFilterChange} totalResults={sorted.length} />
        </div>

        {/* Mobile filter overlay */}
        <AnimatePresence>
          {mobileFilterOpen && (
            <>
              <motion.div
                initial={{ opacity: 0 }}
                animate={{ opacity: 1 }}
                exit={{ opacity: 0 }}
                className="fixed inset-0 z-40 bg-black/40 backdrop-blur-sm lg:hidden"
                onClick={() => setMobileFilterOpen(false)}
              />
              <motion.div
                initial={{ x: '-100%' }}
                animate={{ x: 0 }}
                exit={{ x: '-100%' }}
                transition={{ type: 'spring', damping: 30, stiffness: 300 }}
                className="fixed inset-y-0 left-0 z-50 w-[var(--layout-sidebar-sm)] max-w-[85vw] bg-card shadow-modal lg:hidden overflow-y-auto"
              >
                <div className="flex items-center justify-between p-4 border-b border-border">
                  <span className="font-semibold font-display">Filter</span>
                  <button
                    type="button"
                    onClick={() => setMobileFilterOpen(false)}
                    className="btn-icon-sm flex items-center justify-center min-w-[var(--space-10)] min-h-[var(--space-10)]"
                    aria-label="Filter schließen"
                  >
                    <X size={18} />
                  </button>
                </div>
                <div className="p-4">
                  <FilterSidebar filters={filters} onChange={handleFilterChange} totalResults={sorted.length} className="!sticky !top-0 !border-0 !shadow-none !bg-transparent !backdrop-blur-none" />
                </div>
              </motion.div>
            </>
          )}
        </AnimatePresence>

        {/* Content area */}
        <div className="flex-1 min-w-0">
          {viewMode === 'map' ? (
            <div className="space-y-6">
              <MapView vehicles={sorted} />
              <div className="grid grid-cols-1 sm:grid-cols-2 gap-5">
                {paginated.map((vehicle, i) => (
                  <VehicleCard
                    key={vehicle.id}
                    vehicle={vehicle}
                    index={i}
                    variant="grid"
                  />
                ))}
              </div>
            </div>
          ) : viewMode === 'list' ? (
            <div className="space-y-4">
              {paginated.map((vehicle, i) => (
                <VehicleCard
                  key={vehicle.id}
                  vehicle={vehicle}
                  index={i}
                  variant="list"
                />
              ))}
            </div>
          ) : (
            <div className="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-5">
              {paginated.map((vehicle, i) => (
                <VehicleCard
                  key={vehicle.id}
                  vehicle={vehicle}
                  index={i}
                  variant="grid"
                />
              ))}
            </div>
          )}

          {/* Empty state */}
          {sorted.length === 0 && (
            <div className="flex flex-col items-center justify-center py-20 text-center">
              <p className="text-h3 font-display mb-2">
                Keine Fahrzeuge gefunden
              </p>
              <p className="text-muted-foreground max-w-md">
                Versuchen Sie andere Filtereinstellungen oder schauen Sie sich
                unser gesamtes Angebot an.
              </p>
              <Link href="/fahrzeuge" className="btn btn-primary mt-6">
                Alle Fahrzeuge
              </Link>
            </div>
          )}

          {/* Pagination */}
          {totalPages > 1 && (
            <nav
              aria-label="Seitennavigation"
              className="flex items-center justify-center gap-2 mt-12"
            >
              <button
                type="button"
                onClick={() => setCurrentPage((p) => Math.max(1, p - 1))}
                disabled={currentPage === 1}
                className={cn(
                  'btn btn-outline btn-sm min-w-[var(--space-10)] min-h-[var(--space-10)]',
                  currentPage === 1 && 'opacity-40 pointer-events-none'
                )}
              >
                Zurück
              </button>

              {Array.from({ length: totalPages }, (_, i) => i + 1).map(
                (page) => (
                  <button
                    key={page}
                    type="button"
                    onClick={() => setCurrentPage(page)}
                    className={cn(
                      'w-10 h-10 flex items-center justify-center rounded-lg text-sm font-medium transition-all',
                      'min-w-[var(--space-10)] min-h-[var(--space-10)]',
                      page === currentPage
                        ? 'bg-foreground text-background'
                        : 'text-muted-foreground hover:bg-muted hover:text-foreground'
                    )}
                    aria-current={page === currentPage ? 'page' : undefined}
                  >
                    <span className="font-mono tabular-nums">{page}</span>
                  </button>
                )
              )}

              <button
                type="button"
                onClick={() =>
                  setCurrentPage((p) => Math.min(totalPages, p + 1))
                }
                disabled={currentPage === totalPages}
                className={cn(
                  'btn btn-outline btn-sm min-w-[var(--space-10)] min-h-[var(--space-10)]',
                  currentPage === totalPages &&
                    'opacity-40 pointer-events-none'
                )}
              >
                Weiter
              </button>
            </nav>
          )}

          {/* Results summary */}
          <p className="text-center text-sm text-muted-foreground mt-6">
            Zeige{' '}
            <span className="font-mono tabular-nums">
              {(currentPage - 1) * ITEMS_PER_PAGE + 1}
            </span>
            –
            <span className="font-mono tabular-nums">
              {Math.min(currentPage * ITEMS_PER_PAGE, sorted.length)}
            </span>{' '}
            von{' '}
            <span className="font-mono tabular-nums">{sorted.length}</span>{' '}
            Fahrzeugen
          </p>
        </div>
      </div>
    </div>
  );
}
'use client';

import { MagazineGallery } from '@/components/sections/magazine-gallery';
import { BuyingCard } from '@/components/sections/buying-card';
import { MarketPriceMeter } from '@/components/sections/market-price-meter';
import { FeatureGrid } from '@/components/sections/feature-grid';
import { SpecsTable } from '@/components/sections/specs-table';
import { DetailedTimeline } from '@/components/sections/detailed-timeline';
import { DealerSignals } from '@/components/sections/dealer-signals';
import type { Vehicle, Dealer } from '@/types/inventory';

interface VehicleDetailClientProps {
  vehicle: Vehicle;
  dealer: Dealer;
}

export function VehicleDetailClient({ vehicle, dealer }: VehicleDetailClientProps) {
  return (
    <div className="flex flex-col lg:flex-row gap-8">
      {/* Main Content Column */}
      <div className="flex-1 min-w-0 space-y-10">
        {/* Magazine Gallery */}
