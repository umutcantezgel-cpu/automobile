            { value: '38', label: 'Jahre' },
            { value: '★ 4.9', label: 'Google Bewertung' },
          ].map((stat) => (
            <motion.div key={stat.label} variants={fadeUp} className="flex flex-col items-center gap-1 py-8 px-4">
