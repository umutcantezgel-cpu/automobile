                              width: 'calc(var(--space-1) * 14)',
                              height: 'calc(var(--space-1) * 9.5)',
                              borderRadius: 'var(--radius-md)',
                              aspectRatio: 'auto',
                            }}
                          >
                            <div className="veh-img-shape" />
                          </div>
                          <div className="min-w-0">
                            <div className="text-[length:var(--t-sm)] font-medium truncate">
                              {v.make} {v.model}
