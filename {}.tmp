          >
            {/* Service chip selector */}
            <div>
              <label className="text-sm font-medium mb-3 block">Serviceleistung</label>
              <div className="flex flex-wrap gap-2">
                {SERVICE_OPTIONS.map((opt) => (
                  <button
                    key={opt}
                    type="button"
                    onClick={() => setSelectedService(opt)}
                    className={cn(
                      'btn btn-sm rounded-full transition-colors min-h-[var(--space-10)]',
                      selectedService === opt
                        ? 'bg-primary text-primary-foreground'
                        : 'btn-outline'
                    )}
                  >
                    {opt}
                  </button>
                ))}
              </div>
            </div>

            {/* Vehicle */}
            <div>
              <label htmlFor="bk-vehicle" className="text-sm font-medium mb-1.5 block">
                Fahrzeug
              </label>
              <input
                id="bk-vehicle"
                type="text"
                value={vehicle}
                onChange={(e) => setVehicle(e.target.value)}
                placeholder="z. B. Audi A4 Avant 2.0 TDI"
                className="input"
                required
              />
            </div>

            {/* Date + Time */}
            <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label htmlFor="bk-date" className="text-sm font-medium mb-1.5 block">
                  <CalendarDays size={14} className="inline mr-1.5 -mt-0.5 opacity-50" />
                  Wunschtermin
                </label>
                <input
                  id="bk-date"
                  type="date"
                  value={date}
                  onChange={(e) => setDate(e.target.value)}
                  className="input font-mono tabular-nums"
                  required
                />
              </div>
              <div>
                <label className="text-sm font-medium mb-1.5 block">
                  <Clock size={14} className="inline mr-1.5 -mt-0.5 opacity-50" />
                  Uhrzeit
                </label>
                <div className="grid grid-cols-4 gap-2">
                  {TIME_SLOTS.map((slot) => (
                    <button
                      key={slot}
                      type="button"
                      onClick={() => setTime(slot)}
                      className={cn(
                        'btn btn-sm font-mono tabular-nums min-h-[var(--space-10)] rounded-lg',
                        time === slot
                          ? 'bg-primary text-primary-foreground'
                          : 'btn-outline'
                      )}
                    >
                      {slot}
                    </button>
                  ))}
                </div>
              </div>
            </div>

            {/* Submit */}
            <button
              type="submit"
              className="btn btn-primary btn-lg w-full gap-2 min-h-[var(--space-10)]"
            >
              <Send size={16} />
              Termin anfragen
            </button>

            {/* Toast */}
            {submitted && (
              <motion.div
                initial={{ opacity: 0, y: 8 }}
                animate={{ opacity: 1, y: 0 }}
                exit={{ opacity: 0 }}
                className="flex items-center gap-3 rounded-lg bg-success/10 border border-success/30 text-success px-4 py-3 text-sm font-medium"
              >
                <CheckCircle2 size={18} />
                Terminanfrage wurde gesendet. Wir melden uns in Kürze.
              </motion.div>
            )}
          </motion.form>
        </div>
      </section>

      {/* ============================================================ */}
      {/*  WORKSHOP TEAM                                               */}
      {/* ============================================================ */}
      <section className="section-y bg-muted/40">
        <div className="container-x">
          <motion.div
            initial={{ opacity: 0, y: 20 }}
            whileInView={{ opacity: 1, y: 0 }}
            viewport={{ once: true, margin: '-10%' }}
            transition={{ duration: 0.6, ease: [0.16, 1, 0.3, 1] as const }}
            className="mb-12"
          >
            <p className="eyebrow mb-3">{'// Unser Team'}</p>
            <h2 className="text-h1">Die Werkstatt-Crew</h2>
          </motion.div>

          <motion.div
            variants={stagger}
            initial="hidden"
            whileInView="visible"
            viewport={{ once: true, margin: '-5%' }}
            className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5"
          >
            {TEAM.map((member) => (
              <motion.div
                key={member.initials}
                variants={fadeUp}
                className="card p-6 flex flex-col items-center text-center gap-4"
              >
                {/* Avatar */}
                <div
                  className={cn(
                    'w-16 h-16 rounded-full flex items-center justify-center',
                    'bg-gradient-to-br text-white font-display text-lg font-bold',
                    member.gradient
                  )}
                >
                  {member.initials}
                </div>
                <div>
                  <h4 className="text-h4">{member.name}</h4>
                  <p className="text-sm text-muted-foreground mt-0.5">{member.role}</p>
                  <p className="text-xs text-muted-foreground mt-1">
                    <span className="font-mono tabular-nums">{member.years}</span> Jahre Erfahrung
                  </p>
                </div>
              </motion.div>
            ))}
          </motion.div>
        </div>
      </section>
    </main>
  );
}
'use client';

import { useState, useMemo } from 'react';
import { motion, AnimatePresence } from 'framer-motion';
import { useForm, Controller } from 'react-hook-form';
import { zodResolver } from '@hookform/resolvers/zod';
import { z } from 'zod';
import { Check, ArrowRight, ArrowLeft, Calendar, Clock, User, ShieldCheck, CheckCircle2, ChevronLeft, ChevronRight, Info, Gauge } from 'lucide-react';
import { cn } from '@/lib/cn';
import { VEHICLES } from '@/lib/mock/vehicles';
import { formatPrice, formatPower } from '@/lib/format';

const schema = z.object({
  vehicleId: z.string().min(1, { message: 'Bitte wählen Sie ein Fahrzeug' }),
  date: z.string().min(1, { message: 'Bitte wählen Sie ein Datum' }),
  time: z.string().min(1, { message: 'Bitte wählen Sie eine Uhrzeit' }),
  firstName: z.string().min(1, { message: 'Pflichtfeld' }),
  lastName: z.string().min(1, { message: 'Pflichtfeld' }),
  email: z.string()0ail({ message: 'Ungültige E-Mail Adresse' }),
  phone: z.string().min(5, { message: 'Pflichtfeld' }),
  license: z.string().min(5, { message: 'Pflichtfeld' }),
  birthdate: z.string().min(5, { message: 'Pflichtfeld' }),
});

type FormValues = z.infer<typeof schema>;

const TIME_SLOTS = ['09:00', '10:30', '13:00', '14:30', '16:00', '17:30'];

export default function TestDrivePage() {
  const [step, setStep] = useState(1);
  const [direction, setDirection] = useState(1);
  
  // For calendar
  const [currentMonth, setCurrentMonth] = useState(new Date(2026, 5)); // June 2026 based on metadata
  
  const topVehicles = VEHICLES.slice(0, 4);

  const { control, watch, setValue, trigger, formState: { errors } } = useForm<FormValues>({
    resolver: zodResolver(schema),
    defaultValues: {
      vehicleId: topVehicles[0].id,
      date: '',
      time: '',
      firstName: '',
      lastName: '',
      email: '',
      phone: '',
      license: '',
      birthdate: ''
    },
    mode: 'onChange'
  });

  const values = watch();
  const selectedVehicle = VEHICLES.find(v => v.id === values.vehicleId) || topVehicles[0];

  const handleNext = async () => {
    let fieldsToValidate: any[] = [];
    if (step === 1) fieldsToValidate = ['vehicleId'];
    if (step === 2) fieldsToValidate = ['date', 'time'];
    if (step === 3) fieldsToValidate = ['firstName', 'lastName', 'email', 'phone', 'license', 'birthdate'];

    const isValid = await trigger(fieldsToValidate as any);
    if (isValid && step < 4) {
      setDirection(1);
      setStep(s => s + 1);
    }
  };

  const handleBack = () => {
    if (step > 1 && step < 4) {
      setDirection(-1);
      setStep(s => s - 1);
    }
  };

  const isStepValid = () => {
    if (step === 1) return !!values.vehicleId;
    if (step === 2) return !!values.date && !!values.time;
    if (step === 3) return !errors.firstName && !errors.lastName && !errors0ail && !errors.phone && !errors.license && !errors.birthdate && !!values.firstName;
    return true;
  };

  const daysInMonth = new Date(currentMonth.getFullYear(), currentMonth.getMonth() + 1, 0).getDate();
  const firstDayOfMonth = new Date(currentMonth.getFullYear(), currentMonth.getMonth(), 1).getDay();
  
  // Adjust for Monday start (0 = Mon, 6 = Sun)
  const startOffset = firstDayOfMonth === 0 ? 6 : firstDayOfMonth - 1;
  const calendarDays = Array.from({ length: 42 }, (_, i) => {
    const dayNum = i - startOffset + 1;
    if (dayNum > 0 && dayNum <= daysInMonth) return dayNum;
    return null;
  });

  const variants = {
    enter: (dir: number) => ({ x: dir > 0 ? 30 : -30, opacity: 0 }),
    center: { x: 0, opacity: 1 },
    exit: (dir: number) => ({ x: dir < 0 ? 30 : -30, opacity: 0 })
  };

  return (
    <main className="min-h-screen pt-32 pb-24">
      <section className="container-x">
        <motion.div
          className="mb-12 max-w-2xl"
          initial={{ opacity: 0, y: 20 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ duration: 0.5, ease: "easeOut" as const }}
        >
          <p className="font-mono text-sm font-semibold tracking-widest text-primary uppercase mb-4">// Probefahrt</p>
          <h1 className="font-display text-4xl sm:text-5xl font-semibold tracking-tight mb-4">
            Probefahrt vereinbaren
          </h1>
          <p className="text-lg text-muted-foreground">
            Erleben Sie Ihr Wunschfahrzeug hautnah. Wählen Sie Modell, Zeit und Ort — wir bereiten alles für Sie vor.
          </p>
        </motion.div>

        <div className="grid grid-cols-1 lg:grid-cols-[1.5fr_1fr] gap-12 lg:gap-16 items-start">
          {/* ---- Left: Wizard ---- */}
          <div className="bg-card border border-border rounded-2xl shadow-card overflow-hidden flex flex-col relative min-h-[var(--layout-hero-lg)]">
            {/* Steps Header */}
            {step < 4 && (
              <div className="flex border-b border-border bg-muted/30">
                {[
                  { num: 1, label: 'Fahrzeug', icon: Info },
                  { num: 2, label: 'Termin', icon: Calendar },
                  { num: 3, label: 'Daten', icon: User }
                ].map((s) => (
                  <div 
                    key={s.num} 
                    className={cn(
                      'flex-1 p-4 flex flex-col sm:flex-row items-center justify-center gap-2 text-sm font-semibold transition-colors border-b-2',
                      step === s.num ? 'border-primary text-foreground bg-card' : 
                      step > s.num ? 'border-transparent text-muted-foreground' : 'border-transparent text-muted-foreground/50'
                    )}
                  >
                    <div className={cn(
                      'size-6 rounded-full flex items-center justify-center text-xs font-mono',
                      step >= s.num ? 'bg-primary/10 text-primary' : 'bg-muted-foreground/10'
                    )}>
                      {step > s.num ? <Check className="size-3.5" /> : s.num}
                    </div>
                    <span className="hidden sm:inline">{s.label}</span>
                  </div>
                ))}
              </div>
            )}

            <div className="flex-1 p-6 sm:p-10 relative overflow-x-hidden">
              <AnimatePresence initial={false} custom={direction} mode="wait">
                <motion.div
                  key={step}
                  custom={direction}
                  variants={variants}
                  initial="enter"
                  animate="center"
                  exit="exit"
                  transition={{ duration: 0.3, ease: [0.16, 1, 0.3, 1] as any }}
                  className="w-full"
                >
                  {/* STEP 1: Vehicle */}
                  {step === 1 && (
                    <div className="space-y-6">
                      <h2 className="text-2xl font-semibold mb-6">Wählen Sie ein Fahrzeug</h2>
                      <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        {topVehicles.map(v => (
                          <button
                            key={v.id}
                            onClick={() => {
                              setValue('vehicleId', v.id, { shouldValidate: true });
                            }}
                            className={cn(
                              'relative flex flex-col items-start p-4 rounded-xl border text-left transition-all',
                              values.vehicleId === v.id
                                ? 'border-primary bg-primary/5 ring-1 ring-primary/20 scale-[0.98]'
                                : 'border-border bg-card hover:border-border-strong hover:bg-muted/50'
                            )}
                          >
                            <div className={cn('veh-img mb-3 !aspect-[16/10] !rounded-lg w-full', v.imgAlt)}>
                              <div className="veh-img-grid" />
                              <div className="veh-img-shape" />
                            </div>
                            <span className="text-xs text-muted-foreground uppercase tracking-widest">{v.make}</span>
                            <span className="font-semibold text-lg">{v.model}</span>
                            <span className="text-sm text-muted-foreground mb-3">{formatPower(v.kw, v.hp)}</span>
                            
                            <div className={cn(
                              'absolute top-4 right-4 size-6 rounded-full border-2 flex items-center justify-center transition-colors',
                              values.vehicleId === v.id ? 'border-primary bg-primary text-primary-foreground' : 'border-muted-foreground/30 bg-background/50 backdrop-blur-sm'
                            )}>
                              {values.vehicleId === v.id && <Check className="size-3.5" />}
                            </div>
                          </button>
                        ))}
                      </div>
                    </div>
                  )}

                  {/* STEP 2: Date & Time */}
                  {step === 2 && (
                    <div className="space-y-8">
                      <h2 className="text-2xl font-semibold">Wann möchten Sie fahren?</h2>
                      
                      <div className="grid grid-cols-1 sm:grid-cols-2 gap-8">
                        {/* Calendar */}
                        <div>
                          <div className="flex items-center justify-between mb-4">
                            <span className="font-semibold">{currentMonth.toLocaleString('de-DE', { month: 'long', year: 'numeric' })}</span>
                            <div className="flex gap-2">
                              <button onClick={() => setCurrentMonth(new Date(currentMonth.getFullYear(), currentMonth.getMonth() - 1))} className="p-1.5 rounded-lg border border-border hover:bg-muted">
                                <ChevronLeft className="size-4" />
                              </button>
                              <button onClick={() => setCurrentMonth(new Date(currentMonth.getFullYear(), currentMonth.getMonth() + 1))} className="p-1.5 rounded-lg border border-border hover:bg-muted">
                                <ChevronRight className="size-4" />
                              </button>
                            </div>
                          </div>
                          
                          <div className="grid grid-cols-7 gap-1 text-center mb-2">
                            {['Mo', 'Di', 'Mi', 'Do', 'Fr', 'Sa', 'So'].map(d => (
                              <div key={d} className="text-xs font-medium text-muted-foreground py-2">{d}</div>
                            ))}
                          </div>
                          
                          <div className="grid grid-cols-7 gap-1">
                            {calendarDays.map((day, i) => {
                              if (!day) return <div key={i} className="aspect-square" />;
                              
                              const dateStr = `${currentMonth.getFullYear()}-${String(currentMonth.getMonth() + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
                              const isSelected = values.date === dateStr;
                              const isWeekend = i % 7 >= 5; // Sa = 5, So = 6
                              
                              return (
                                <button
                                  key={i}
                                  disabled={isWeekend}
                                  onClick={() => setValue('date', dateStr, { shouldValidate: true })}
                                  className={cn(
                                    'aspect-square flex items-center justify-center rounded-lg text-sm font-medium transition-all min-h-[var(--space-10)]',
                                    isSelected ? 'bg-primary text-primary-foreground shadow-glow-primary scale-110 z-10' :
                                    isWeekend ? 'text-muted-foreground/30 bg-muted/20 cursor-not-allowed' :
                                    'bg-muted/50 hover:bg-muted text-foreground'
                                  )}
                                >
                                  {day}
                                </button>
                              );
                            })}
                          </div>
                        </div>

                        {/* Times */}
                        <div>
                          <span className="font-semibold block mb-4 flex items-center gap-2">
                            <Clock className="size-4 text-primary" />
                            Uhrzeit wählen
                          </span>
                          <div className="grid grid-cols-2 gap-3">
                            {TIME_SLOTS.map(time => (
                              <button
                                key={time}
                                disabled={!values.date}
                                onClick={() => setValue('time', time, { shouldValidate: true })}
                                className={cn(
                                  'py-3 px-4 rounded-xl border text-sm font-mono font-semibold transition-all min-h-[var(--space-10)]',
                                  !values.date ? 'opacity-50 cursor-not-allowed border-border bg-card' :
                                  values.time === time
                                    ? 'border-primary bg-primary/10 text-primary ring-1 ring-primary/20'
                                    : 'border-border bg-card hover:border-border-strong text-foreground'
                                )}
                              >
                                {time}
                              </button>
                            ))}
                          </div>
                          {!values.date && (
                            <p className="text-xs text-muted-foreground mt-4 flex items-start gap-1.5">
                              <Info className="size-3.5 mt-0.5 shrink-0" />
                              Bitte wählen Sie zuerst ein Datum, um verfügbare Zeiten zu sehen.
                            </p>
                          )}
                        </div>
                      </div>
                    </div>
                  )}

                  {/* STEP 3: Personal Data */}
                  {step === 3 && (
                    <div className="space-y-6">
                      <h2 className="text-2xl font-semibold mb-6">Ihre Kontaktdaten</h2>
                      
                      <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div className="space-y-2">
                          <label className="text-sm font-semibold text-muted-foreground">Vorname</label>
                          <Controller
                            name="firstName"
                            control={control}
                            render={({ field }) => (
                              <input {...field} className="w-full bg-card border border-border rounded-xl px-4 py-3 min-h-[var(--space-10)] focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary/20 transition-all" />
                            )}
                          />
                        </div>
                        <div className="space-y-2">
                          <label className="text-sm font-semibold text-muted-foreground">Nachname</label>
                          <Controller
                            name="lastName"
                            control={control}
                            render={({ field }) => (
                              <input {...field} className="w-full bg-card border border-border rounded-xl px-4 py-3 min-h-[var(--space-10)] focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary/20 transition-all" />
                            )}
                          />
                        </div>
                      </div>

                      <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div className="space-y-2">
                          <label className="text-sm font-semibold text-muted-foreground">E-Mail Adresse</label>
                          <Controller
                            name="email"
                            control={control}
                            render={({ field }) => (
                              <input {...field} type="email" className={cn("w-full bg-card border rounded-xl px-4 py-3 min-h-[var(--space-10)] focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary/20 transition-all", errors0ail ? 'border-destructive' : 'border-border')} />
                            )}
                          />
                        </div>
                        <div className="space-y-2">
                          <label className="text-sm font-semibold text-muted-foreground">Telefonnummer</label>
                          <Controller
                            name="phone"
                            control={control}
                            render={({ field }) => (
                              <input {...field} type="tel" className="w-full bg-card border border-border font-mono rounded-xl px-4 py-3 min-h-[var(--space-10)] focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary/20 transition-all" />
                            )}
                          />
                        </div>
                      </div>

                      <div className="border-t border-border pt-6 mt-6">
                        <h3 className="font-semibold mb-4 flex items-center gap-2">
                          <ShieldCheck className="size-4 text-primary" />
                          Verifizierungsdaten
                        </h3>
                        <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
                          <div className="space-y-2">
                            <label className="text-sm font-semibold text-muted-foreground">Führerschein-Nr.</label>
                            <Controller
                              name="license"
                              control={control}
                              render={({ field }) => (
                                <input {...field} className="w-full bg-card border border-border font-mono rounded-xl px-4 py-3 min-h-[var(--space-10)] focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary/20 transition-all" placeholder="z.B. B1234567" />
                              )}
                            />
                          </div>
                          <div className="space-y-2">
                            <label className="text-sm font-semibold text-muted-foreground">Geburtsdatum</label>
                            <Controller
                              name="birthdate"
                              control={control}
                              render={({ field }) => (
                                <input {...field} type="date" className="w-full bg-card border border-border rounded-xl px-4 py-3 min-h-[var(--space-10)] focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary/20 transition-all" />
                              )}
                            />
                          </div>
                        </div>
                      </div>
                    </div>
                  )}

                  {/* STEP 4: Success */}
                  {step === 4 && (
                    <div className="flex flex-col items-center justify-center text-center py-12">
                      <motion.div
                        initial={{ scale: 0, opacity: 0 }}
                        animate={{ scale: 1, opacity: 1 }}
                        transition={{ type: "spring", stiffness: 200, damping: 20 }}
                        className="mb-6 text-primary"
                      >
                        <CheckCircle2 className="size-24" />
                      </motion.div>
                      <h2 className="text-3xl font-display font-semibold mb-4">Ihre Probefahrt ist gebucht!</h2>
                      <p className="text-muted-foreground mb-8 max-w-md">
                        Wir freuen uns auf Sie, {values.firstName}. Eine Bestätigung wurde soeben an <span className="font-semibold text-foreground">{values0ail}</span> gesendet.
                      </p>
                      
                      <div className="w-full max-w-sm bg-muted/30 border border-border rounded-xl p-5 text-left mb-8 space-y-3">
                        <div className="flex justify-between items-center pb-3 border-b border-border/50">
                          <span className="text-sm text-muted-foreground">Termin</span>
                          <span className="font-mono text-sm font-semibold">{values.date} · {values.time}</span>
                        </div>
                        <div className="flex justify-between items-center">
                          <span className="text-sm text-muted-foreground">Fahrzeug</span>
                          <span className="text-sm font-semibold">{selectedVehicle.make} {selectedVehicle.model}</span>
                        </div>
                      </div>

                      <button onClick={() => window.location.href = '/'} className="font-semibold text-sm text-primary hover:underline">
                        Zurück zur Startseite
                      </button>
                    </div>
                  )}
                </motion.div>
              </AnimatePresence>
            </div>

            {/* Navigation Footer */}
            {step < 4 && (
              <div className="border-t border-border bg-muted/20 p-6 flex items-center justify-between mt-auto">
                <button
                  onClick={handleBack}
                  disabled={step === 1}
                  className={cn(
                    'flex items-center gap-2 font-semibold text-sm transition-all min-h-[var(--space-10)]',
                    step === 1 ? 'opacity-0 pointer-events-none' : 'text-muted-foreground hover:text-foreground'
                  )}
                >
                  <ArrowLeft className="size-4" />
                  Zurück
                </button>
                
                <button
                  onClick={handleNext}
                  disabled={!isStepValid()}
                  className="flex min-h-[var(--space-10)] items-center gap-2 rounded-xl bg-primary px-6 py-2.5 text-sm font-semibold text-primary-foreground transition-all disabled:opacity-50 disabled:cursor-not-allowed hover:opacity-90 active:scale-[0.98] shadow-glow-primary"
                >
                  {step === 3 ? 'Termin verbindlich buchen' : 'Weiter'}
                  {step < 3 && <ArrowRight className="size-4" />}
                </button>
              </div>
            )}
          </div>

          {/* ---- Right: Sticky Vehicle Info ---- */}
          <div className="sticky top-32 hidden lg:block">
            <h3 className="font-mono text-xs font-bold uppercase tracking-widest text-muted-foreground mb-4">Ihre Auswahl</h3>
            <div className="bg-card border border-border rounded-2xl p-5 shadow-card">
              <div className={cn('veh-img mb-4 !aspect-[16/10] !rounded-xl w-full', selectedVehicle.imgAlt)}>
                <div className="veh-img-grid" />
                <div className="veh-img-shape" />
              </div>
              <div className="mb-4 pb-4 border-b border-border/50">
                <span className="text-xs text-muted-foreground uppercase tracking-widest block mb-1">{selectedVehicle.make}</span>
                <h4 className="font-display text-2xl font-semibold leading-tight">{selectedVehicle.model}</h4>
                <p className="text-sm text-muted-foreground mt-1">{selectedVehicle.variant}</p>
              </div>
              
              <div className="space-y-3">
                <div className="flex justify-between items-center text-sm">
                  <span className="text-muted-foreground flex items-center gap-2"><Gauge className="size-4" /> Leistung</span>
                  <span className="font-mono font-medium">{formatPower(selectedVehicle.kw, selectedVehicle.hp)}</span>
                </div>
                <div className="flex justify-between items-center text-sm">
                  <span className="text-muted-foreground flex items-center gap-2"><Calendar className="size-4" /> Erstzulassung</span>
                  <span className="font-mono font-medium">{selectedVehicle.year}</span>
                </div>
                <div className="flex justify-between items-center text-sm">
                  <span className="text-muted-foreground flex items-center gap-2"><User className="size-4" /> Preis</span>
                  <span className="font-mono font-medium text-primary">{formatPrice(selectedVehicle.price)}</span>
                </div>
              </div>

              {step > 1 && values.date && values.time && (
                <div className="mt-6 pt-4 border-t border-border border-dashed">
                  <p className="text-xs text-muted-foreground uppercase tracking-widest mb-2">Gewählter Termin</p>
                  <div className="flex items-center gap-3 bg-muted/50 p-3 rounded-xl border border-border">
                    <Calendar className="size-5 text-primary" />
                    <div>
                      <div className="font-mono font-semibold text-sm">{values.date}</div>
                      <div className="text-xs text-muted-foreground">{values.time} Uhr</div>
                    </div>
                  </div>
                </div>
              )}
            </div>
          </div>
        </div>
      </section>
    </main>
  );
}
import Link from 'next/link';
import {
  ArrowRight,
  Wrench,
  Calculator,
  RefreshCw,
  Shield,
  Star,
  Car,
  Users,
  Award,
} from 'lucide-react';
import { cn } from '@/lib/cn';
import { formatPrice, formatKm } from '@/lib/format';
import { VEHICLES, BRANDS } from '@/lib/mock/vehicles';
import type { Vehicle } from '@/types/inventory';

import { Hero } from '@/components/sections/hero';
import { QuickSearch } from '@/components/sections/quick-search';
import { VehicleCard } from '@/components/sections/vehicle-card';

/* ================================================================== */
/*  BigFeatured Card — first vehicle spans 2 cols × 2 rows            */
/* ================================================================== */

function BigFeatured({ vehicle }: { vehicle: Vehicle }) {
  return (
    <article
      className={cn(
        'group relative col-span-1 row-span-1 flex flex-col overflow-hidden',
        'rounded-[var(--radius-xl)] border border-border bg-card',
        'shadow-[var(--shadow-card)]',
        'transition-[box-shadow,transform] duration-[350ms]',
        'hover:shadow-[var(--shadow-card-hover)] hover:-translate-y-px',
        'md:col-span-2 md:row-span-2',
        vehicle.isPremium && 'card-top-listing'
      )}
      style={{ transitionTimingFunction: 'cubic-bezier(0.16, 1, 0.3, 1)' }}
    >
      {/* Image */}
      <Link href={`/fahrzeuge/${vehicle.id}`} className="block flex-1 min-h-[var(--layout-card-img)]">
        <div className={cn('veh-img h-full', vehicle.imgAlt)} style={{ aspectRatio: 'auto' }}>
          <div className="veh-img-grid" />
          <div className="veh-img-shape" />
          <span className="veh-img-tag">
            {vehicle.make} {vehicle.model}
          </span>
        </div>
      </Link>

      {/* Badge */}
      {vehicle.tag && (
        <span
          className={cn(
            'absolute top-4 left-4 z-10',
            vehicle.isPremium ? 'badge-top-listing' : 'badge badge-primary'
          )}
        >
          {vehicle.tag}
        </span>
      )}

      {/* Content */}
      <div className="flex flex-col gap-4 p-6 sm:p-8">
        {/* Eyebrow */}
        <p className="eyebrow">// Featured · Sondermodell</p>

        {/* Title */}
        <div>
          <h3 className="text-h3 text-foreground">
            {vehicle.make} {vehicle.model}
          </h3>
          {vehicle.variant && (
            <p className="mt-1 text-[length:var(--t-sm)] text-muted-foreground">{vehicle.variant}</p>
          )}
        </div>

        {/* Description */}
        <p className="text-[length:var(--t-sm)] leading-relaxed text-muted-foreground line-clamp-2">
          {vehicle.desc}
        </p>

        {/* Price + Meta row */}
        <div className="flex flex-wrap items-end justify-between gap-4 border-t border-border pt-4">
          <div>
            {vehicle.oldPrice && (
              <p className="line-strike font-mono text-[length:var(--t-xs)] tabular-nums text-muted-foreground">
                {formatPrice(vehicle.oldPrice)}
              </p>
            )}
            <p className="font-[family-name:var(--font-display)] text-2xl font-bold tracking-tight text-foreground">
              <span className="font-mono tabular-nums">{formatPrice(vehicle.price)}</span>
            </p>
            {vehicle.monthly && (
              <p className="mt-0.5 font-mono text-[length:var(--t-xs)] tabular-nums text-muted-foreground">
                ab {new Intl.NumberFormat('de-DE').format(vehicle.monthly)} €/Monat
              </p>
            )}
          </div>
          <div className="flex gap-4 text-[length:var(--t-xs)] text-muted-foreground">
            <span className="font-mono tabular-nums">{vehicle.year}</span>
            <span className="font-mono tabular-nums">{formatKm(vehicle.km)}</span>
          </div>
        </div>

        {/* CTA */}
        <Link
          href={`/fahrzeuge/${vehicle.id}`}
          className="btn btn-primary self-start"
        >
          Details ansehen
          <ArrowRight className="h-4 w-4" />
        </Link>
      </div>
    </article>
  );
}

/* ================================================================== */
/*  Section Header                                                     */
/* ================================================================== */

function SectionHeader({
  eyebrow,
  title,
  className,
}: {
  eyebrow: string;
  title: string;
  className?: string;
}) {
  return (
    <div className={cn('mb-12', className)}>
      <p className="eyebrow mb-3">{eyebrow}</p>
      <h2 className="text-h2 text-foreground">{title}</h2>
    </div>
  );
}

/* ================================================================== */
/*  Service Card                                                       */
/* ================================================================== */

interface ServiceData {
  icon: typeof Wrench;
  title: string;
  desc: string;
  link: string;
}

const SERVICES: ServiceData[] = [
  {
    icon: Wrench,
    title: 'Werkstatt & Service',
    desc: 'Markenübergreifende Wartung und Reparatur mit zertifizierten Technikern. Garantiert erstklassige Arbeit.',
    link: '/service',
  },
  {
    icon: Calculator,
    title: 'Finanzierung',
    desc: 'Maßgeschneiderte Finanzierungsoptionen. Leasing, Ballonkredit oder klassische Ratenfinanzierung — transparent kalkuliert.',
    link: '/finanzierung',
  },
  {
    icon: RefreshCw,
    title: 'Inzahlungnahme',
    desc: 'Wir bewerten Ihr Fahrzeug fair und unkompliziert. Sofort-Kaufangebot innerhalb von 24 Stunden.',
    link: '/inzahlungnahme',
  },
  {
    icon: Shield,
    title: 'Garantie & Schutz',
    desc: 'Erweiterte Garantie-Programme bis 48 Monate. Rundum-Schutz für Ihr Premium-Fahrzeug.',
    link: '/garantie',
  },
];

function ServiceCard({ service }: { service: ServiceData }) {
  const Icon = service.icon;
  return (
    <Link
      href={service.link}
      className={cn(
        'card card-hoverable group flex flex-col gap-4 p-6',
        'hover:border-primary/20'
      )}
    >
      <div
        className={cn(
          'flex h-12 w-12 items-center justify-center rounded-[var(--radius-DEFAULT)]',
          'bg-primary/5 text-primary transition-colors duration-300 group-hover:bg-primary/10'
        )}
      >
        <Icon className="h-6 w-6" />
      </div>
      <h3 className="font-[family-name:var(--font-display)] text-lg font-semibold text-foreground">
        {service.title}
      </h3>
      <p className="text-[length:var(--t-sm)] leading-relaxed text-muted-foreground">
        {service.desc}
      </p>
      <span
        className={cn(
          'mt-auto inline-flex items-center gap-1.5 self-start',
          'font-[family-name:var(--font-mono)] text-[length:var(--t-xs)] font-semibold uppercase tracking-wider',
          'text-primary transition-colors'
        )}
      >
        Mehr erfahren
        <ArrowRight className="h-3.5 w-3.5 transition-transform group-hover:translate-x-1" />
      </span>
    </Link>
  );
}

/* ================================================================== */
/*  Testimonial Card                                                   */
/* ================================================================== */

interface TestimonialData {
  name: string;
  car: string;
  quote: string;
}

const TESTIMONIALS: TestimonialData[] = [
  {
    name: 'M. Schreiber',
    car: 'Audi RS6',
    quote: 'Vom ersten Kontakt bis zur Übergabe — ein Erlebnis, kein Prozess.',
  },
  {
    name: 'Dr. K. Lindner',
    car: 'Porsche 911',
    quote: 'Transparenz, Kompetenz, null Druck. So muss Autohandel sein.',
  },
  {
    name: 'A. Yilmaz',
    car: 'Mercedes GLE',
    quote: 'Ich habe mein Traumauto gefunden und dabei mehr gespart als erwartet.',
  },
];

function TestimonialCard({ testimonial }: { testimonial: TestimonialData }) {
  return (
    <div className="card flex flex-col gap-4 p-6">
      {/* Stars */}
      <div className="flex gap-0.5">
        {Array.from({ length: 5 }).map((_, i) => (
          <Star key={i} className="h-4 w-4 fill-premium text-premium" />
        ))}
      </div>

      {/* Quote */}
      <blockquote className="flex-1 text-[length:var(--t-base)] leading-relaxed text-foreground italic">
        &ldquo;{testimonial.quote}&rdquo;
      </blockquote>

      {/* Author */}
      <div className="border-t border-border pt-4">
        <p className="font-[family-name:var(--font-display)] text-[length:var(--t-sm)] font-semibold text-foreground">
          {testimonial.name}
        </p>
        <p className="mt-0.5 text-[length:var(--t-xs)] text-muted-foreground">{testimonial.car}</p>
      </div>
    </div>
  );
}

/* ================================================================== */
/*  Trust Counter                                                      */
/* ================================================================== */

interface TrustCounter {
  value: string;
  label: string;
  icon: typeof Car;
}

const TRUST_COUNTERS: TrustCounter[] = [
  { value: '38', label: 'Jahre Erfahrung', icon: Award },
  { value: '12.400+', label: 'Fahrzeuge verkauft', icon: Car },
  { value: '4,9/5', label: 'Trustpilot', icon: Star },
  { value: '15', label: 'Mitarbeiter', icon: Users },
];

function TrustCounterCard({ counter }: { counter: TrustCounter }) {
  const Icon = counter.icon;
  return (
    <div className="card flex flex-col items-center gap-3 p-6 text-center">
      <div className="flex h-10 w-10 items-center justify-center rounded-full bg-primary/5 text-primary">
        <Icon className="h-5 w-5" />
      </div>
      <p className="font-mono text-3xl font-bold tabular-nums text-foreground">
        {counter.value}
      </p>
      <p className="text-[length:var(--t-sm)] text-muted-foreground">{counter.label}</p>
    </div>
  );
}

/* ================================================================== */
/*  Homepage                                                           */
/* ================================================================== */

const featuredVehicles = VEHICLES.slice(0, 5);

export default function Home() {
  return (
    <>
      {/* ────────────────────────────────────────────────────────── */}
      {/* Section 1 — Hero                                          */}
      {/* ────────────────────────────────────────────────────────── */}
      <Hero />

      {/* ────────────────────────────────────────────────────────── */}
      {/* Section 2 — QuickSearch (overlapping hero)                */}
      {/* ────────────────────────────────────────────────────────── */}
      <QuickSearch />

      {/* ────────────────────────────────────────────────────────── */}
      {/* Section 3 — Featured Vehicles Bento                       */}
      {/* ────────────────────────────────────────────────────────── */}
      <section className="section-y container-x">
        <SectionHeader eyebrow="// 01 · Featured" title="Aktuell im Showroom" />

        <div className="grid grid-cols-1 gap-6 md:grid-cols-4 md:grid-rows-2">
          {/* Big featured — first vehicle, 2 cols × 2 rows */}
          <BigFeatured vehicle={featuredVehicles[0]} />

          {/* Remaining vehicles */}
          {featuredVehicles.slice(1).map((vehicle, i) => (
            <VehicleCard key={vehicle.id} vehicle={vehicle} variant="grid" index={i + 1} />
          ))}
        </div>

        <div className="mt-10 flex justify-center">
          <Link
            href="/fahrzeuge"
            className="btn btn-ghost"
          >
            Alle Fahrzeuge anzeigen
            <ArrowRight className="h-4 w-4" />
          </Link>
        </div>
      </section>

      {/* ────────────────────────────────────────────────────────── */}
      {/* Section 4 — Brand Showcase                                */}
      {/* ────────────────────────────────────────────────────────── */}
      <section className="section-y border-t border-b border-border bg-card-elevated">
        <div className="container-x mb-8">
          <p className="eyebrow">
            // Premium-Partner · <span className="font-mono tabular-nums">42</span> Marken im Bestand
          </p>
        </div>
        <div className="container-x">
          <div className="brand-row">
            {BRANDS.map((brand) => (
              <Link
                key={brand}
                href={`/fahrzeuge?marke=${encodeURIComponent(brand)}`}
                className={cn(
                  'shrink-0 rounded-[var(--radius-DEFAULT)] border border-border bg-card',
                  'px-5 py-2.5 font-[family-name:var(--font-display)] text-[length:var(--t-sm)] font-semibold text-foreground',
                  'transition-all duration-200',
                  'hover:border-primary hover:text-primary'
                )}
              >
                {brand}
              </Link>
            ))}
          </div>
        </div>
      </section>

      {/* ────────────────────────────────────────────────────────── */}
      {/* Section 5 — Services Bento                                */}
      {/* ────────────────────────────────────────────────────────── */}
      <section className="section-y container-x">
        <SectionHeader eyebrow="// 02 · Services" title="Mehr als nur Fahrzeuge" />
        <div className="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {SERVICES.map((s) => (
            <ServiceCard key={s.title} service={s} />
          ))}
        </div>
      </section>

      {/* ────────────────────────────────────────────────────────── */}
      {/* Section 6 — Testimonials                                  */}
      {/* ────────────────────────────────────────────────────────── */}
      <section className="section-y border-t border-border bg-card-elevated">
        <div className="container-x">
          <SectionHeader
            eyebrow="// 03 · Stimmen"
            title="Was Kund:innen über uns sagen."
          />
          <div className="grid grid-cols-1 gap-6 md:grid-cols-3">
            {TESTIMONIALS.map((t) => (
              <TestimonialCard key={t.name} testimonial={t} />
            ))}
          </div>
        </div>
      </section>

      {/* ────────────────────────────────────────────────────────── */}
      {/* Section 7 — Trust Counters                                */}
      {/* ────────────────────────────────────────────────────────── */}
      <section className="section-y container-x">
        <div className="grid grid-cols-2 gap-6 lg:grid-cols-4">
          {TRUST_COUNTERS.map((c) => (
            <TrustCounterCard key={c.label} counter={c} />
          ))}
        </div>
      </section>
    </>
  );
}
import Link from 'next/link';

export default function NotFound() {
  return (
    <section className="container-x flex min-h-[var(--layout-hero-lg)] flex-col items-center justify-center text-center section-y">
      {/* Eyebrow */}
      <p className="eyebrow mb-4">// 404 · Seite nicht gefunden</p>

      {/* Heading */}
      <h1 className="text-h1 mb-4">Diese Seite existiert nicht.</h1>

      {/* Description */}
      <p className="mx-auto max-w-md text-lg text-muted-foreground">
        Die angeforderte Seite wurde nicht gefunden oder ist nicht mehr
        verfügbar.
      </p>

      {/* CTAs */}
      <div className="mt-10 flex flex-col gap-4 sm:flex-row">
        <Link
          href="/"
          className="btn btn-primary btn-lg"
        >
          Zur Startseite
        </Link>

        <Link
          href="/fahrzeuge"
          className="btn btn-ghost btn-lg"
        >
          Fahrzeuge entdecken
        </Link>
      </div>
    </section>
  );
}
'use client';

import { AnimatePresence, motion } from 'framer-motion';
import type { ReactNode } from 'react';

const PAGE_VARIANTS = {
  hidden: { opacity: 0, y: 8 },
  enter: { opacity: 1, y: 0 },
  exit: { opacity: 0, y: -8 },
} as const;

const PAGE_TRANSITION = {
  duration: 0.4,
  ease: [0.42, 0, 0.58, 1] as const,
} as const;

export default function Template({ children }: { children: ReactNode }) {
  return (
    <AnimatePresence mode="wait">
      <motion.div
        initial="hidden"
        animate="enter"
        exit="exit"
        variants={PAGE_VARIANTS}
        transition={PAGE_TRANSITION}
      >
        {children}
      </motion.div>
    </AnimatePresence>
  );
}
