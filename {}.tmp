              </div>
              <div className="font-display text-[length:var(--t-3xl)] font-bold tracking-tight font-mono tabular-nums">
                {kpi.value}
              </div>
              <div className="flex items-center gap-1.5 text-[length:var(--t-xs)]">
                {kpi.trendIcon && (
                  <span style={{ color: kpi.trendColor }}>{kpi.trendIcon}</span>
                )}
                <span
                  style={{
                    color: kpi.trendColor || 'var(--color-muted-foreground)',
                    fontWeight: kpi.trendColor ? 600 : 400,
                  }}
                >
                  {kpi.sub}
                </span>
              </div>
            </div>
          </motion.div>
        ))}
      </div>

      {/* ── Two-column: Activity + Leads ── */}
      <div className="grid gap-6 grid-cols-[1.6fr_1fr] items-start">
        {/* Activity Table */}
        <motion.div
          className="adm-card"
          variants={fadeUp}
          initial="hidden"
          animate="show"
          custom={4}
        >
          <div className="adm-card-head">
            <div className="flex items-center gap-3">
              <div className="adm-card-icon">
                <Activity size={18} />
              </div>
              <div>
                <h3 className="text-[length:var(--t-base)] font-semibold" style={{ fontFamily: 'var(--font-display)' }}>
                  Letzte Aktivität
                </h3>
