import Link from 'next/link';
import { motion, AnimatePresence } from 'framer-motion';
import {
  ChevronDown,
  MapPin,
  Clock,
  Briefcase,
  Coffee,
  GraduationCap,
  CarFront,
  Users,
  PiggyBank,
