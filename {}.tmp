        </div>
      </section>
    </main>
  );
}
'use client';

import { useState, useMemo, useCallback } from 'react';
import { motion } from 'framer-motion';
import Link from 'next/link';
import {
  ArrowRight,
  TrendingUp,
  TrendingDown,
  AlertTriangle,
  Zap,
  Smartphone,
  Search,
  ShieldCheck,
  Clock,
  Users,
  BarChart3,
  Target,
  ChevronRight,
  Lightbulb,
  Calculator,
  Building2,
} from 'lucide-react';
import { cn } from '@/lib/cn';
import { Button } from '@/components/ui/button';
import { Badge } from '@/components/ui/badge';

/* ================================================================== */
/*  TYPES                                                              */
/* ================================================================== */

interface IndustryPreset {
  id: string;
  label: string;
  aov: number;
  traffic: number;
  leads: number;
  conversionRate: number;
}

interface SliderConfig {
  min: number;
  max: number;
  step: number;
  label: string;
  unit: string;
  formatValue?: (v: number) => string;
}

interface LossSegment {
  id: string;
  label: string;
  icon: React.ReactNode;
  color: string;
  strokeColor: string;
}

interface QuickWin {
  icon: React.ReactNode;
  title: string;
  description: string;
  impact: string;
  badge: string;
}

/* ================================================================== */
/*  INDUSTRY PRESETS                                                    */
/* ================================================================== */

const INDUSTRY_PRESETS: IndustryPreset[] = [
  { id: 'autohandel-klein', label: 'Autohandel (klein)', aov: 18000, traffic: 1200, leads: 12, conversionRate: 1.0 },
  { id: 'autohandel-mittel', label: 'Autohandel (mittel)', aov: 28000, traffic: 3400, leads: 28, conversionRate: 0.82 },
  { id: 'autohandel-premium', label: 'Autohandel (premium)', aov: 65000, traffic: 2200, leads: 14, conversionRate: 0.64 },
  { id: 'autohandel-gruppe', label: 'Autohandel (Gruppe)', aov: 32000, traffic: 8400, leads: 78, conversionRate: 0.93 },
  { id: 'werkstatt', label: 'Werkstatt', aov: 480, traffic: 4200, leads: 142, conversionRate: 3.4 },
  { id: 'leasing', label: 'Leasing', aov: 24000, traffic: 5600, leads: 38, conversionRate: 0.68 },
];

const LOSS_SEGMENTS: LossSegment[] = [
  { id: 'load', label: 'Ladezeit', icon: <Clock className="w-4 h-4" />, color: 'var(--color-red-600)', strokeColor: 'var(--color-red-600)' },
  { id: 'mobile', label: 'Mobil', icon: <Smartphone className="w-4 h-4" />, color: 'var(--color-orange-600)', strokeColor: 'var(--color-orange-600)' },
  { id: 'seo', label: 'SEO', icon: <Search className="w-4 h-4" />, color: 'var(--color-gold-600)', strokeColor: 'var(--color-gold-600)' },
  { id: 'trust', label: 'Vertrauen', icon: <ShieldCheck className="w-4 h-4" />, color: 'var(--color-blue-600)', strokeColor: 'var(--color-blue-600)' },
];

/* Benchmark targets */
const TARGET_CONVERSION = 4.0;
const CLOSE_RATE = 0.2;

/* ================================================================== */
/*  FORMATTING HELPERS                                                 */
/* ================================================================== */

function fmtEur(n: number): string {
  return new Intl.NumberFormat('de-DE', { style: 'currency', currency: 'EUR', maximumFractionDigits: 0 }).format(Math.round(n));
}

function fmtNum(n: number): string {
  return new Intl.NumberFormat('de-DE').format(Math.round(n));
}

function fmtPct(n: number, digits = 2): string {
  return n.toFixed(digits).replace('.', ',') + ' %';
}

/* ================================================================== */
/*  RANGE SLIDER COMPONENT                                             */
/* ================================================================== */

function RangeSlider({
  config,
  value,
  onChange,
}: {
  config: SliderConfig;
  value: number;
  onChange: (v: number) => void;
}) {
  const percentage = ((value - config.min) / (config.max - config.min)) * 100;
  const displayValue = config.formatValue ? config.formatValue(value) : `${fmtNum(value)} ${config.unit}`;

  return (
    <div>
      <div className="flex items-center justify-between mb-2">
        <label className="text-sm font-medium text-foreground">{config.label}</label>
        <span className="font-mono text-sm tabular-nums font-semibold text-primary">{displayValue}</span>
      </div>
      <div className="relative">
        <input
          type="range"
          min={config.min}
          max={config.max}
          step={config.step}
          value={value}
          onChange={(e) => onChange(Number(e.target.value))}
          className="w-full h-2 appearance-none bg-transparent cursor-pointer relative z-10
            [&::-webkit-slider-thumb]:appearance-none [&::-webkit-slider-thumb]:w-5 [&::-webkit-slider-thumb]:h-5
            [&::-webkit-slider-thumb]:rounded-full [&::-webkit-slider-thumb]:bg-primary [&::-webkit-slider-thumb]:border-2
            [&::-webkit-slider-thumb]:border-card [&::-webkit-slider-thumb]:shadow-md [&::-webkit-slider-thumb]:cursor-pointer
            [&::-webkit-slider-thumb]:transition-transform [&::-webkit-slider-thumb]:hover:scale-110
            [&::-moz-range-thumb]:w-5 [&::-moz-range-thumb]:h-5 [&::-moz-range-thumb]:rounded-full
            [&::-moz-range-thumb]:bg-primary [&::-moz-range-thumb]:border-2 [&::-moz-range-thumb]:border-card
            [&::-moz-range-thumb]:shadow-md [&::-moz-range-thumb]:cursor-pointer min-h-11"
        />
        <div className="absolute top-1/2 -translate-y-1/2 left-0 right-0 h-2 rounded-full bg-muted overflow-hidden pointer-events-none">
          <div
            className="h-full bg-primary/30 rounded-full transition-all duration-150"
            style={{ width: `${percentage}%` }}
          />
        </div>
      </div>
      <div className="flex justify-between mt-1">
        <span className="text-[length:var(--t-2xs)] text-muted-foreground font-mono tabular-nums">
          {config.formatValue ? config.formatValue(config.min) : `${fmtNum(config.min)}`}
        </span>
        <span className="text-[length:var(--t-2xs)] text-muted-foreground font-mono tabular-nums">
          {config.formatValue ? config.formatValue(config.max) : `${fmtNum(config.max)}`}
        </span>
      </div>
    </div>
  );
}

/* ================================================================== */
/*  DONUT CHART COMPONENT (SVG)                                        */
/* ================================================================== */

function DonutChart({
  segments,
}: {
  segments: { label: string; value: number; color: string }[];
}) {
  const total = segments.reduce((acc, s) => acc + s.value, 0);
  const radius = 80;
  const circumference = 2 * Math.PI * radius;
  let cumulativeOffset = 0;

  return (
    <div className="relative inline-flex items-center justify-center">
      <svg width="200" height="200" viewBox="0 0 200 200" className="transform -rotate-90">
        {/* Background circle */}
        <circle cx="100" cy="100" r={radius} fill="none" stroke="var(--color-off-white-200)" strokeWidth="24" />
        {/* Segments */}
        {segments.map((seg) => {
          const segLength = total > 0 ? (seg.value / total) * circumference : 0;
          const offset = cumulativeOffset;
          cumulativeOffset += segLength;
          return (
            <circle
              key={seg.label}
              cx="100"
              cy="100"
              r={radius}
              fill="none"
              stroke={seg.color}
              strokeWidth="24"
              strokeDasharray={`${segLength} ${circumference - segLength}`}
              strokeDashoffset={-offset}
              strokeLinecap="round"
              className="transition-all duration-700 ease-out"
            />
          );
        })}
      </svg>
      <div className="absolute inset-0 flex flex-col items-center justify-center">
        <span className="font-mono text-2xl tabular-nums font-bold text-foreground">
          {total > 0 ? fmtPct(Math.min(total, 100), 0).replace(',00', '') : '0 %'}
        </span>
        <span className="text-[length:var(--t-2xs)] text-muted-foreground">Gesamtverlust</span>
      </div>
    </div>
  );
}

/* ================================================================== */
/*  BAR CHART COMPONENT                                                */
/* ================================================================== */

function BarComparison({
  label1,
  value1,
  label2,
  value2,
  unit,
}: {
  label1: string;
  value1: number;
  label2: string;
  value2: number;
  unit: string;
}) {
  const maxVal = Math.max(value1, value2, 1);

  return (
    <div className="space-y-3">
      {/* Current */}
      <div>
        <div className="flex items-center justify-between mb-1">
          <span className="text-xs text-muted-foreground">{label1}</span>
          <span className="font-mono text-sm tabular-nums font-semibold">{unit === '€' ? fmtEur(value1) : fmtNum(value1)}</span>
        </div>
        <div className="h-6 bg-muted rounded-lg overflow-hidden">
          <motion.div
            className="h-full bg-muted-foreground/30 rounded-lg"
            initial={{ width: 0 }}
            animate={{ width: `${(value1 / maxVal) * 100}%` }}
            transition={{ duration: 0.8, ease: "easeOut" as const }}
          />
        </div>
      </div>
      {/* Possible */}
      <div>
        <div className="flex items-center justify-between mb-1">
          <span className="text-xs text-muted-foreground">{label2}</span>
          <span className="font-mono text-sm tabular-nums font-bold text-success">{unit === '€' ? fmtEur(value2) : fmtNum(value2)}</span>
        </div>
        <div className="h-6 bg-muted rounded-lg overflow-hidden">
          <motion.div
            className="h-full bg-success rounded-lg"
            initial={{ width: 0 }}
            animate={{ width: `${(value2 / maxVal) * 100}%` }}
            transition={{ duration: 0.8, ease: "easeOut" as const, delay: 0.15 }}
          />
        </div>
      </div>
    </div>
  );
}

/* ================================================================== */
/*  5-YEAR PROJECTION CHART                                            */
/* ================================================================== */

function ProjectionChart({ yearlyDiff }: { yearlyDiff: number }) {
  const years = [1, 2, 3, 4, 5];
  const values = years.map((y) => yearlyDiff * y);
  const maxVal = Math.max(...values, 1);

  return (
    <div className="flex items-end gap-2 h-32">
      {years.map((y, i) => (
        <div key={y} className="flex-1 flex flex-col items-center gap-1">
          <span className="font-mono text-[length:var(--t-2xs)] tabular-nums text-muted-foreground">
            {values[i] >= 1000000
              ? `${(values[i] / 1000000).toFixed(1).replace('.', ',')} M€`
              : values[i] >= 1000
              ? `${Math.round(values[i] / 1000)}k€`
              : fmtEur(values[i])}
          </span>
          <motion.div
            className="w-full bg-primary rounded-t-md min-h-[var(--space-1)]"
            initial={{ height: 0 }}
            animate={{ height: `${(values[i] / maxVal) * 100}%` }}
            transition={{ duration: 0.6, delay: i * 0.1, ease: "easeOut" as const }}
            style={{ maxHeight: '100%' }}
          />
          <span className="font-mono text-[length:var(--t-2xs)] tabular-nums text-muted-foreground">
            Jahr {y}
          </span>
        </div>
      ))}
    </div>
  );
}

/* ================================================================== */
/*  SECTION HEADER                                                     */
/* ================================================================== */

function SectionHeader({ number, title }: { number: string; title: string }) {
  return (
    <div className="flex items-center gap-2.5 mb-5">
      <span className="flex items-center justify-center w-6 h-6 rounded-md bg-primary/10 font-mono text-[length:var(--t-2xs)] font-bold text-primary tabular-nums">
        {number}
      </span>
      <h3 className="font-display font-semibold text-sm uppercase tracking-wide">{title}</h3>
    </div>
  );
}

/* ================================================================== */
/*  MAIN PAGE COMPONENT                                                */
/* ================================================================== */

export default function CalculatorPage() {
  /* ── Inputs ──────────────────────────────────────────────────────── */
  const [presetId, setPresetId] = useState<string>('autohandel-mittel');
  const [aov, setAov] = useState<number>(28000);
  const [visitors, setVisitors] = useState<number>(3400);
  const [inquiries, setInquiries] = useState<number>(28);
  const [loadTime, setLoadTime] = useState<number>(4.2);
  const [mobileScore, setMobileScore] = useState<number>(45);
  const [googlePosition, setGooglePosition] = useState<number>(14);
  const [trustSignals, setTrustSignals] = useState<number>(2);

  /* ── Apply preset ────────────────────────────────────────────────── */
  const applyPreset = useCallback((id: string) => {
    const preset = INDUSTRY_PRESETS.find((p) => p.id === id);
    if (!preset) return;
    setPresetId(id);
    setAov(preset.aov);
    setVisitors(preset.traffic);
    setInquiries(preset.leads);
  }, []);

  /* ── Derived current conversion ─────────────────────────────────── */
  const currentConversion = useMemo(() => {
    if (visitors === 0) return 0;
    return (inquiries / visitors) * 100;
  }, [visitors, inquiries]);

  /* ── Loss factor calculations ───────────────────────────────────── */
  const lossFactors = useMemo(() => {
    // Load time loss: every second above 2s = ~7% conversion loss
    const loadLoss = Math.max(0, (loadTime - 2) * 7);
    // Mobile score loss: (100 - score) * 0.35
    const mobileLoss = Math.max(0, (100 - mobileScore) * 0.35);
    // SEO position loss: positions beyond 3 lose ~5% click-through each
    const seoLoss = Math.max(0, (googlePosition - 3) * 5);
    // Trust loss: lacking signals from max 8, each missing = ~4%
    const trustLoss = Math.max(0, (8 - trustSignals) * 4);

    const totalLoss = Math.min(loadLoss + mobileLoss + seoLoss + trustLoss, 95);

    return { loadLoss, mobileLoss, seoLoss, trustLoss, totalLoss };
  }, [loadTime, mobileScore, googlePosition, trustSignals]);

  /* ── Revenue calculations ───────────────────────────────────────── */
  const calculations = useMemo(() => {
    const currentLeadsPerMonth = inquiries;
    const currentRevenuePerMonth = currentLeadsPerMonth * CLOSE_RATE * aov;
    const currentRevenuePerYear = currentRevenuePerMonth * 12;

    // Target scenario: 4% conversion rate
    const targetLeadsPerMonth = (visitors * TARGET_CONVERSION) / 100;
    const targetRevenuePerMonth = targetLeadsPerMonth * CLOSE_RATE * aov;
    const targetRevenuePerYear = targetRevenuePerMonth * 12;

    const lostLeadsPerMonth = Math.max(0, targetLeadsPerMonth - currentLeadsPerMonth);
    const monthlyLoss = Math.max(0, targetRevenuePerMonth - currentRevenuePerMonth);
    const yearlyLoss = monthlyLoss * 12;

    const growthFactor = currentRevenuePerMonth > 0
      ? targetRevenuePerMonth / currentRevenuePerMonth
      : 0;

    return {
      currentLeadsPerMonth,
      currentRevenuePerMonth,
      currentRevenuePerYear,
      targetLeadsPerMonth,
      targetRevenuePerMonth,
      targetRevenuePerYear,
      lostLeadsPerMonth,
      monthlyLoss,
      yearlyLoss,
      growthFactor,
    };
  }, [visitors, inquiries, aov]);

  /* ── Donut segments ─────────────────────────────────────────────── */
  const donutSegments = useMemo(() => {
    const { loadLoss, mobileLoss, seoLoss, trustLoss } = lossFactors;
    return [
      { label: 'Ladezeit', value: loadLoss, color: LOSS_SEGMENTS[0].color },
      { label: 'Mobil', value: mobileLoss, color: LOSS_SEGMENTS[1].color },
      { label: 'SEO', value: seoLoss, color: LOSS_SEGMENTS[2].color },
      { label: 'Vertrauen', value: trustLoss, color: LOSS_SEGMENTS[3].color },
    ];
  }, [lossFactors]);

  /* ── Quick wins ─────────────────────────────────────────────────── */
  const quickWins = useMemo((): QuickWin[] => {
    const wins: QuickWin[] = [];

    if (loadTime > 3) {
      wins.push({
        icon: <Zap className="w-5 h-5" />,
        title: 'Ladezeit optimieren',
        description: `Ihre Ladezeit von ${loadTime.toFixed(1).replace('.', ',')}s kostet Sie ca. ${fmtPct(lossFactors.loadLoss, 0)} Conversion. Ziel: unter 2s.`,
        impact: `+${Math.round(lossFactors.loadLoss)}% Conv.`,
        badge: 'Hoch',
      });
    }

    if (mobileScore < 70) {
      wins.push({
        icon: <Smartphone className="w-5 h-5" />,
        title: 'Mobile Experience verbessern',
        description: `Ein Mobile-Score von ${mobileScore}/100 bedeutet, dass über 60% Ihrer Besucher eine schlechte Erfahrung haben.`,
        impact: `+${Math.round(lossFactors.mobileLoss)}% Conv.`,
        badge: 'Kritisch',
      });
    }

    if (googlePosition > 5) {
      wins.push({
        icon: <Search className="w-5 h-5" />,
        title: 'SEO-Position verbessern',
        description: `Position ${googlePosition} auf Google bedeutet, dass nur ~${Math.max(1, Math.round(30 / googlePosition))}% der Suchenden Ihre Seite sehen.`,
        impact: `+${Math.round(lossFactors.seoLoss)}% Sichtbarkeit`,
        badge: 'Mittel',
      });
    }

    if (trustSignals < 5) {
      wins.push({
        icon: <ShieldCheck className="w-5 h-5" />,
        title: 'Vertrauenssignale hinzufügen',
        description: `Sie nutzen nur ${trustSignals} von 8 möglichen Trust-Elementen. Bewertungen, Zertifikate und Garantien steigern die Conversion.`,
        impact: `+${Math.round(lossFactors.trustLoss)}% Vertrauen`,
        badge: 'Einfach',
      });
    }

    if (currentConversion < 2) {
      wins.push({
        icon: <Target className="w-5 h-5" />,
        title: 'Conversion-Rate verdoppeln',
        description: `Ihre aktuelle Rate von ${fmtPct(currentConversion)} liegt deutlich unter dem Branchendurchschnitt von 4%. Gezielte CTA-Optimierung kann das ändern.`,
        impact: `${fmtEur(calculations.monthlyLoss)}/Mon.`,
        badge: 'ROI',
      });
    }

    return wins.slice(0, 3);
  }, [loadTime, mobileScore, googlePosition, trustSignals, lossFactors, currentConversion, calculations.monthlyLoss]);

  /* ── SLIDER CONFIGS ─────────────────────────────────────────────── */
  const aovSlider: SliderConfig = {
    min: 200,
    max: 120000,
    step: 100,
    label: 'Ø Auftragswert',
    unit: '€',
    formatValue: (v) => fmtEur(v),
  };

  const visitorsSlider: SliderConfig = {
    min: 100,
    max: 20000,
    step: 50,
    label: 'Besucher / Monat',
    unit: '',
    formatValue: (v) => fmtNum(v),
  };

  const inquiriesSlider: SliderConfig = {
    min: 0,
    max: 500,
    step: 1,
    label: 'Anfragen / Monat',
    unit: '',
    formatValue: (v) => fmtNum(v),
  };

  const loadTimeSlider: SliderConfig = {
    min: 0.5,
    max: 12,
    step: 0.1,
    label: 'Ladezeit (Sekunden)',
    unit: 's',
    formatValue: (v) => `${v.toFixed(1).replace('.', ',')} s`,
  };

  const mobileScoreSlider: SliderConfig = {
    min: 0,
    max: 100,
    step: 1,
    label: 'Mobile Score',
    unit: '/100',
    formatValue: (v) => `${v}/100`,
  };

  const googlePosSlider: SliderConfig = {
    min: 1,
    max: 100,
    step: 1,
    label: 'Google-Position (Hauptkeyword)',
    unit: '',
    formatValue: (v) => `Position ${v}`,
  };

  const trustSlider: SliderConfig = {
    min: 0,
    max: 8,
    step: 1,
    label: 'Vertrauenssignale',
    unit: '/8',
    formatValue: (v) => `${v} von 8`,
  };

  /* ================================================================ */
  /*  RENDER                                                           */
  /* ================================================================ */

  return (
    <div className="min-h-screen bg-background">
      {/* ============================================================ */}
      {/*  HERO                                                         */}
      {/* ============================================================ */}
      <section className="section-y relative overflow-hidden">
        <div className="absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,color-mix(in_srgb,var(--color-primary)_6%,transparent),transparent)]" />
        <div className="container-x relative">
          <motion.div
            initial={{ opacity: 0, y: 20 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.6 }}
            className="max-w-3xl mx-auto text-center"
          >
            <p className="eyebrow mb-6">// Umsatzverlust-Rechner · für Autohäuser</p>
            <h1 className="text-h1 mb-6">
              Wie viel verlieren Sie jeden Monat
              <br />
              <span className="text-primary">durch Ihre Website?</span>
            </h1>
            <p className="text-body-lg text-muted-foreground max-w-xl mx-auto">
              Geben Sie Ihre aktuellen Zahlen ein und sehen Sie sofort,
              welches Umsatzpotenzial Sie ungenutzt lassen.
            </p>
          </motion.div>
        </div>
      </section>

      {/* ============================================================ */}
      {/*  CALCULATOR                                                   */}
      {/* ============================================================ */}
      <section className="pb-24">
        <div className="container-x">
          <div className="flex flex-col lg:flex-row gap-8 items-start">
            {/* ──────────────────────────────────────────────────────── */}
            {/*  LEFT: INPUT PANEL                                       */}
            {/* ──────────────────────────────────────────────────────── */}
            <motion.div
              initial={{ opacity: 0, x: -20 }}
              animate={{ opacity: 1, x: 0 }}
              transition={{ duration: 0.5, delay: 0.1 }}
              className="w-full lg:w-[var(--layout-sidebar-md)] lg:sticky lg:top-24 shrink-0 space-y-6"
            >
              {/* Section 01: Unternehmens-Profil */}
              <div className="p-5 rounded-xl border border-border bg-card shadow-card">
                <SectionHeader number="01" title="Unternehmens-Profil" />

                {/* Preset select */}
                <div className="mb-5">
                  <label className="text-sm font-medium text-foreground mb-2 block">Branche & Größe</label>
                  <div className="relative">
                    <Building2 className="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-muted-foreground pointer-events-none" />
                    <select
                      value={presetId}
                      onChange={(e) => applyPreset(e.target.value)}
                      className={cn(
                        'w-full h-11 rounded-[var(--radius-DEFAULT)] bg-muted pl-9 pr-3 text-sm text-foreground',
                        'border border-border appearance-none cursor-pointer',
                        'focus:outline-none focus:ring-2 focus:ring-ring/40 focus:border-primary',
                        'transition-colors duration-200 min-h-11'
                      )}
                    >
                      {INDUSTRY_PRESETS.map((p) => (
                        <option key={p.id} value={p.id}>
                          {p.label}
                        </option>
                      ))}
                    </select>
                    <ChevronRight className="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-muted-foreground pointer-events-none rotate-90" />
                  </div>
                </div>

                <RangeSlider config={aovSlider} value={aov} onChange={setAov} />
              </div>

              {/* Section 02: Online-Aktivität */}
              <div className="p-5 rounded-xl border border-border bg-card shadow-card">
                <SectionHeader number="02" title="Online-Aktivität" />

                <div className="space-y-5">
                  <RangeSlider config={visitorsSlider} value={visitors} onChange={setVisitors} />
                  <RangeSlider config={inquiriesSlider} value={inquiries} onChange={setInquiries} />

                  {/* Derived conversion display */}
                  <div className="p-3 rounded-lg bg-muted/50 border border-border/50">
                    <div className="flex items-center justify-between">
                      <span className="text-xs text-muted-foreground">Aktuelle Conversion-Rate</span>
                      <span className={cn(
                        'font-mono text-sm tabular-nums font-bold',
                        currentConversion >= TARGET_CONVERSION ? 'text-success' : 'text-destructive'
                      )}>
                        {fmtPct(currentConversion)}
                      </span>
                    </div>
                    <div className="flex items-center justify-between mt-1">
                      <span className="text-xs text-muted-foreground">Branchen-Benchmark</span>
                      <span className="font-mono text-xs tabular-nums text-muted-foreground">{fmtPct(TARGET_CONVERSION)}</span>
                    </div>
                  </div>
                </div>
              </div>

              {/* Section 03: Website-Qualität */}
              <div className="p-5 rounded-xl border border-border bg-card shadow-card">
                <SectionHeader number="03" title="Website-Qualität" />

                <div className="space-y-5">
                  <RangeSlider config={loadTimeSlider} value={loadTime} onChange={setLoadTime} />
                  <RangeSlider config={mobileScoreSlider} value={mobileScore} onChange={setMobileScore} />
                  <RangeSlider config={googlePosSlider} value={googlePosition} onChange={setGooglePosition} />
                  <RangeSlider config={trustSlider} value={trustSignals} onChange={setTrustSignals} />
                </div>
              </div>
            </motion.div>

            {/* ──────────────────────────────────────────────────────── */}
            {/*  RIGHT: DASHBOARD                                        */}
            {/* ──────────────────────────────────────────────────────── */}
            <motion.div
              initial={{ opacity: 0, x: 20 }}
              animate={{ opacity: 1, x: 0 }}
              transition={{ duration: 0.5, delay: 0.2 }}
              className="flex-1 space-y-6 min-w-0"
            >
              {/* KPI Strip */}
              <div className="grid grid-cols-1 sm:grid-cols-3 gap-4">
                {/* Current conversion */}
                <div className="p-5 rounded-xl border border-border bg-card shadow-card">
                  <div className="flex items-center gap-2 mb-2">
                    <span className={cn(
                      'p-1.5 rounded-md',
                      currentConversion >= TARGET_CONVERSION ? 'bg-success/10 text-success' : 'bg-destructive/10 text-destructive'
                    )}>
                      {currentConversion >= TARGET_CONVERSION
                        ? <TrendingUp className="w-4 h-4" />
                        : <TrendingDown className="w-4 h-4" />}
                    </span>
                    <span className="text-xs text-muted-foreground">Conversion</span>
                  </div>
                  <p className={cn(
                    'font-mono text-2xl tabular-nums font-bold',
                    currentConversion >= TARGET_CONVERSION ? 'text-success' : 'text-destructive'
                  )}>
                    {fmtPct(currentConversion)}
                  </p>
                  <p className="text-[length:var(--t-2xs)] text-muted-foreground mt-0.5">
                    Ziel: <span className="font-mono tabular-nums">{fmtPct(TARGET_CONVERSION)}</span>
                  </p>
                </div>

                {/* Lost leads */}
                <div className="p-5 rounded-xl border border-border bg-card shadow-card">
                  <div className="flex items-center gap-2 mb-2">
                    <span className="p-1.5 rounded-md bg-warning/10 text-warning">
                      <AlertTriangle className="w-4 h-4" />
                    </span>
                    <span className="text-xs text-muted-foreground">Verlorene Leads/Mon.</span>
                  </div>
                  <p className="font-mono text-2xl tabular-nums font-bold text-foreground">
                    {fmtNum(calculations.lostLeadsPerMonth)}
                  </p>
                  <p className="text-[length:var(--t-2xs)] text-muted-foreground mt-0.5">
                    Möglich: <span className="font-mono tabular-nums">{fmtNum(calculations.targetLeadsPerMonth)}</span>/Mon.
                  </p>
                </div>

                {/* Growth factor */}
                <div className="p-5 rounded-xl border border-border bg-card shadow-card">
                  <div className="flex items-center gap-2 mb-2">
                    <span className="p-1.5 rounded-md bg-primary/10 text-primary">
                      <BarChart3 className="w-4 h-4" />
                    </span>
                    <span className="text-xs text-muted-foreground">Wachstumsfaktor</span>
                  </div>
                  <p className="font-mono text-2xl tabular-nums font-bold text-primary">
                    {calculations.growthFactor > 0 ? `${calculations.growthFactor.toFixed(1).replace('.', ',')}x` : '–'}
                  </p>
                  <p className="text-[length:var(--t-2xs)] text-muted-foreground mt-0.5">
                    Potenzieller Umsatz-Multiplikator
                  </p>
                </div>
              </div>

              {/* Revenue comparison */}
              <div className="p-6 rounded-xl border border-border bg-card shadow-card">
                <h3 className="font-display font-semibold text-base mb-5 flex items-center gap-2">
                  <BarChart3 className="w-4 h-4 text-primary" />
                  Umsatzvergleich (monatlich)
                </h3>
                <BarComparison
                  label1="Aktueller Umsatz"
                  value1={calculations.currentRevenuePerMonth}
                  label2="Möglicher Umsatz"
                  value2={calculations.targetRevenuePerMonth}
                  unit="€"
                />
                {calculations.monthlyLoss > 0 && (
                  <div className="mt-4 p-3 rounded-lg bg-destructive/5 border border-destructive/10">
                    <div className="flex items-center gap-2">
                      <AlertTriangle className="w-4 h-4 text-destructive shrink-0" />
                      <span className="text-sm">
                        <span className="font-semibold">Monatlicher Umsatzverlust:</span>{' '}
                        <span className="font-mono tabular-nums font-bold text-destructive">{fmtEur(calculations.monthlyLoss)}</span>
                      </span>
                    </div>
                  </div>
                )}
              </div>

              {/* Loss donut */}
              <div className="p-6 rounded-xl border border-border bg-card shadow-card">
                <h3 className="font-display font-semibold text-base mb-5 flex items-center gap-2">
                  <Target className="w-4 h-4 text-primary" />
                  Verlustquellen-Analyse
                </h3>
                <div className="flex flex-col sm:flex-row items-center gap-8">
                  <DonutChart segments={donutSegments} />
                  <div className="flex-1 space-y-3">
                    {LOSS_SEGMENTS.map((seg, i) => {
                      const values = [lossFactors.loadLoss, lossFactors.mobileLoss, lossFactors.seoLoss, lossFactors.trustLoss];
                      const val = values[i];
                      return (
                        <div key={seg.id} className="flex items-center gap-3">
                          <span
                            className="w-3 h-3 rounded-full shrink-0"
                            style={{ backgroundColor: seg.color }}
                          />
                          <div className="flex items-center gap-2 flex-1 min-w-0">
                            <span className="text-muted-foreground">{seg.icon}</span>
                            <span className="text-sm truncate">{seg.label}</span>
                          </div>
                          <span className="font-mono text-sm tabular-nums font-semibold shrink-0">
                            {fmtPct(val, 0)}
                          </span>
                        </div>
                      );
                    })}
                    <div className="pt-2 border-t border-border">
                      <div className="flex items-center justify-between">
                        <span className="text-sm font-semibold">Gesamt</span>
                        <span className="font-mono text-sm tabular-nums font-bold text-destructive">
                          {fmtPct(lossFactors.totalLoss, 0)}
                        </span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              {/* 5-year projection */}
              <div className="p-6 rounded-xl border border-border bg-card shadow-card">
                <h3 className="font-display font-semibold text-base mb-5 flex items-center gap-2">
                  <TrendingUp className="w-4 h-4 text-primary" />
                  5-Jahres-Projektion (kumulierter Umsatzverlust)
                </h3>
                <ProjectionChart yearlyDiff={calculations.yearlyLoss} />
                <p className="text-xs text-muted-foreground mt-4 text-center">
                  In 5 Jahren verlieren Sie potenziell{' '}
                  <span className="font-mono tabular-nums font-bold text-destructive">
                    {fmtEur(calculations.yearlyLoss * 5)}
                  </span>{' '}
                  an entgangenem Umsatz.
                </p>
              </div>

              {/* Quick wins */}
              {quickWins.length > 0 && (
                <div className="p-6 rounded-xl border border-border bg-card shadow-card">
                  <h3 className="font-display font-semibold text-base mb-5 flex items-center gap-2">
                    <Lightbulb className="w-4 h-4 text-premium" />
                    Sofort-Empfehlungen
                  </h3>
                  <div className="space-y-4">
                    {quickWins.map((win) => (
                      <div
                        key={win.title}
                        className="flex items-start gap-4 p-4 rounded-lg bg-muted/30 border border-border/50"
                      >
                        <span className="p-2 rounded-lg bg-primary/10 text-primary shrink-0">
                          {win.icon}
                        </span>
                        <div className="flex-1 min-w-0">
                          <div className="flex items-center gap-2 mb-1 flex-wrap">
                            <h4 className="font-display font-semibold text-sm">{win.title}</h4>
                            <Badge
                              variant={win.badge === 'Kritisch' ? 'destructive' : win.badge === 'Hoch' ? 'warning' : 'default'}
                            >
                              {win.badge}
                            </Badge>
                          </div>
                          <p className="text-xs text-muted-foreground leading-relaxed">{win.description}</p>
                        </div>
                        <span className="font-mono text-xs tabular-nums font-bold text-success shrink-0 bg-success/10 px-2 py-1 rounded">
                          {win.impact}
                        </span>
                      </div>
                    ))}
                  </div>
                </div>
              )}

              {/* Final CTA */}
              <div className="p-8 rounded-2xl border border-primary/20 bg-gradient-to-br from-primary/[0.04] to-transparent shadow-card">
                <div className="flex flex-col md:flex-row items-start md:items-center gap-6">
                  <div className="flex-1">
                    <Calculator className="w-8 h-8 text-primary mb-3" />
                    <h3 className="text-h3 mb-2">Ihr jährliches Potenzial:</h3>
                    <p className="font-mono text-3xl tabular-nums font-bold text-primary mb-1">
                      {fmtEur(calculations.yearlyLoss)}
                    </p>
                    <p className="text-sm text-muted-foreground">
                      entgangener Umsatz pro Jahr — bei einer Conversion-Optimierung auf{' '}
                      <span className="font-mono tabular-nums">{fmtPct(TARGET_CONVERSION)}</span>.
                    </p>
                  </div>
                  <div className="flex flex-col gap-3 shrink-0">
                    <Link href="/preise">
                      <Button variant="primary" size="lg">
                        Lösung ansehen
                        <ArrowRight className="w-4 h-4 ml-1" />
                      </Button>
                    </Link>
                    <Button variant="outline" size="lg">
                      Kostenlose Beratung
                      <Users className="w-4 h-4 ml-1" />
                    </Button>
                  </div>
                </div>
              </div>
            </motion.div>
          </div>
        </div>
      </section>
    </div>
  );
}
'use client';

import { useState } from 'react';
import Link from 'next/link';
import { ArrowRight, Mail } from 'lucide-react';
import { cn } from '@/lib/cn';
import { ARTICLES } from '@/lib/mock/articles';
import { Button } from '@/components/ui/button';

const TABS = ['Alle', 'Fahrzeuge', 'Technik', 'Markt', 'Lifestyle'];

export default function MagazinPage() {
  const [activeTab, setActiveTab] = useState('Alle');

  const filteredArticles = activeTab === 'Alle'
    ? ARTICLES
    : ARTICLES.filter(a => a.category === activeTab);

  const displayArticles = filteredArticles.length > 0 ? filteredArticles : ARTICLES;

  const featured = displayArticles[0];
  const rest = displayArticles.slice(1);

  return (
    <main className="container-custom py-24 md:py-32">
      <header className="mb-16 md:mb-24">
        <span className="text-primary font-mono text-sm tracking-wider uppercase mb-4 block">
          // Magazin · Editorial
        </span>
        <h1 className="text-h1 font-display max-w-3xl">
          Lesen, nicht überfliegen.
        </h1>
      </header>

      {/* Tabs */}
      <div className="flex flex-wrap gap-2 mb-12">
        {TABS.map((tab) => (
          <button
            key={tab}
            onClick={() => setActiveTab(tab)}
            className={cn(
              "px-6 py-3 rounded-full text-sm font-medium transition-colors border min-h-[var(--space-10)]",
              activeTab === tab 
                ? "bg-foreground text-background border-foreground" 
                : "bg-transparent text-foreground border-border hover:border-foreground"
            )}
          >
            {tab}
          </button>
        ))}
      </div>

      {/* Featured Article */}
      {featured && (
        <article className="group grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 mb-16 md:mb-24 card p-4 md:p-8 hover:bg-card-elevated transition-colors">
          <Link href={`/magazin/${featured.slug}`} className="block relative aspect-video lg:aspect-[4/3] w-full overflow-hidden rounded-[var(--radius-DEFAULT)]">
            <div className="veh-img w-full h-full alt-0 transition-transform duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-105">
              <div className="veh-img-shape" />
              <div className="veh-img-grid" />
            </div>
          </Link>
          <div className="flex flex-col justify-center py-4">
            <div className="flex items-center gap-4 mb-6">
              <span className="badge badge-primary">{featured.category}</span>
              <span className="font-mono text-sm text-muted-foreground">{featured.date}</span>
            </div>
            <Link href={`/magazin/${featured.slug}`} className="block">
              <h2 className="text-h2 font-display mb-4 group-hover:text-primary transition-colors">
                {featured.title}
              </h2>
            </Link>
            <p className="text-muted-foreground text-lg mb-8 line-clamp-3">
              {featured.excerpt}
            </p>
            <div className="flex items-center gap-6 mt-auto">
              <span className="text-sm font-medium">{featured.author}</span>
              <span className="text-sm text-muted-foreground">·</span>
              <span className="text-sm text-muted-foreground">{featured.readTime}</span>
              <Link href={`/magazin/${featured.slug}`} className="ml-auto flex items-center text-primary font-medium hover:underline min-h-[var(--space-10)]">
                Weiterlesen <ArrowRight size={16} className="ml-2" />
              </Link>
            </div>
          </div>
        </article>
      )}

      {/* Article Grid */}
      {rest.length > 0 && (
        <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-24 md:mb-32">
          {rest.map((article, i) => (
            <article key={article.id} className="group flex flex-col gap-6">
              <Link href={`/magazin/${article.slug}`} className="block relative aspect-video w-full overflow-hidden rounded-[var(--radius-DEFAULT)]">
                <div className={cn("veh-img w-full h-full transition-transform duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-105", `alt-${(i + 1) % 7}`)}>
                  <div className="veh-img-shape" />
                  <div className="veh-img-grid" />
                </div>
              </Link>
              <div className="flex flex-col flex-1">
                <div className="flex items-center gap-3 mb-4">
                  <span className="text-xs font-medium px-3 py-1 bg-muted rounded-full">{article.category}</span>
                  <span className="font-mono text-xs text-muted-foreground">{article.date}</span>
                </div>
                <Link href={`/magazin/${article.slug}`} className="block mb-3">
                  <h3 className="text-h4 font-display group-hover:text-primary transition-colors line-clamp-2">
                    {article.title}
                  </h3>
                </Link>
                <p className="text-muted-foreground text-sm line-clamp-3 mb-6 flex-1">
                  {article.excerpt}
                </p>
                <div className="flex items-center justify-between mt-auto pt-4 border-t border-border">
                  <span className="text-xs text-muted-foreground">{article.readTime}</span>
                  <Link href={`/magazin/${article.slug}`} className="text-sm font-medium hover:text-primary transition-colors flex items-center min-h-[var(--space-10)]">
                    Weiterlesen <ArrowRight size={14} className="ml-1" />
                  </Link>
                </div>
              </div>
            </article>
          ))}
        </div>
      )}

      {/* Newsletter */}
      <section className="bg-foreground text-background rounded-[var(--radius-xl)] p-8 md:p-16 flex flex-col md:flex-row items-center gap-12">
        <div className="flex-1">
          <h2 className="text-h2 font-display mb-4 text-background">Jede Woche neue Perspektiven.</h2>
          <p className="text-background/70 text-lg max-w-xl">
            Abonnieren Sie unseren Newsletter für Editorials, Marktanalysen und exklusive Fahrzeug-Pre-Releases.
          </p>
        </div>
        <form className="w-full md:w-[var(--layout-sidebar-md)] flex gap-2" onSubmit={(e) => e.preventDefault()}>
          <div className="relative flex-1">
            <Mail size={18} className="absolute left-4 top-1/2 -translate-y-1/2 text-background/50" />
            <input
              type="email"
              placeholder="E-Mail Adresse"
              className="w-full h-[var(--space-12)] pl-12 pr-4 bg-background/10 border border-background/20 rounded-[var(--radius-DEFAULT)] text-background placeholder:text-background/50 focus:outline-none focus:border-background transition-colors"
              required
            />
          </div>
          <button type="submit" className="h-[var(--space-12)] px-8 bg-primary text-primary-foreground font-medium rounded-[var(--radius-DEFAULT)] hover:brightness-110 transition-all active:scale-95 whitespace-nowrap min-w-[var(--space-10)]">
            Abonnieren
          </button>
        </form>
      </section>
    </main>
  );
}
'use client';

import { useState } from 'react';
import { motion, AnimatePresence } from 'framer-motion';
import { useForm, Controller } from 'react-hook-form';
import { zodResolver } from '@hookform/resolvers/zod';
import { z } from 'zod';
import { Check, ArrowRight, ArrowLeft, CarFront, Gauge, Calendar, Wrench, Sparkles, CircleDollarSign, BarChart3, Repeat, Info } from 'lucide-react';
import { cn } from '@/lib/cn';
import { BRANDS } from '@/lib/mock/vehicles';

const schema = z.object({
  brand: z.string().min(1, { message: 'Bitte wählen Sie eine Marke' }),
  model: z.string().min(1, { message: 'Bitte wählen Sie ein Modell' }),
  year: z.number({ message: 'Pflichtfeld' } as any)
    .min(2000, { message: 'Muss ab Jahr 2000 sein' })
    .max(2026, { message: 'Muss bis Jahr 2026 sein' }),
  mileage: z.number({ message: 'Pflichtfeld' } as any)
    .min(0, { message: 'Darf nicht negativ sein' })
    .max(500000, { message: 'Maximal 500.000 km' }),
  equipment: z.array(z.string()),
  condition: z.string().min(1, { message: 'Bitte wählen Sie den Zustand' })
});

type FormValues = z.infer<typeof schema>;

const EQUIPMENT_OPTIONS = [
  'Navigationssystem', 'Sitzheizung', 'LED-Scheinwerfer', 'Panoramadach',
  'Rückfahrkamera', 'Standheizung', 'Anhängerkupplung', 'Sportpaket'
];

const CONDITIONS = [
  { id: 'Neuwertig', desc: 'Keine Kratzer, scheckheftgepflegt, wie neu.' },
  { id: 'Sehr gut', desc: 'Minimale Gebrauchsspuren, technisch einwandfrei.' },
  { id: 'Gut', desc: 'Normale Gebrauchsspuren, keine größeren Schäden.' },
  { id: 'Akzeptabel', desc: 'Sichtbare Kratzer oder Dellen, fahrbereit.' },
  { id: 'Mangelhaft', desc: 'Reparaturbedarf, größere Mängel vorhanden.' },
];

export default function TradeInPage() {
  const [step, setStep] = useState(1);
  const [direction, setDirection] = useState(1);

  const { control, watch, setValue, trigger, formState: { errors } } = useForm<FormValues>({
    resolver: zodResolver(schema),
    defaultValues: {
      brand: '',
      model: '',
      year: undefined,
      mileage: undefined,
      equipment: [],
      condition: ''
    },
    mode: 'onChange'
  });

  const values = watch();

  const handleNext = async () => {
    let fieldsToValidate: any[] = [];
    if (step === 1) fieldsToValidate = ['brand'];
    if (step === 2) fieldsToValidate = ['model'];
    if (step === 3) fieldsToValidate = ['year', 'mileage'];
    if (step === 4) fieldsToValidate = ['equipment'];
    if (step === 5) fieldsToValidate = ['condition'];

    const isValid = await trigger(fieldsToValidate as any);
    if (isValid && step < 6) {
      setDirection(1);
      setStep(s => s + 1);
    }
  };

  const handleBack = () => {
    if (step > 1) {
      setDirection(-1);
      setStep(s => s - 1);
    }
  };

  const isStepValid = () => {
    if (step === 1) return !!values.brand;
    if (step === 2) return !!values.model;
    if (step === 3) return !!values.year && !!values.mileage && !errors.year && !errors.mileage;
    if (step === 4) return true; // optional
    if (step === 5) return !!values.condition;
    return true;
  };

  // Mock models based on brand
  const currentModels = values.brand 
    ? [`${values.brand} Kompakt`, `${values.brand} Limousine`, `${values.brand} Kombi`, `${values.brand} SUV`, `${values.brand} Sport`]
    : [];

  const variants = {
    enter: (dir: number) => ({
      x: dir > 0 ? 50 : -50,
      opacity: 0
    }),
    center: {
      zIndex: 1,
      x: 0,
      opacity: 1
    },
    exit: (dir: number) => ({
      zIndex: 0,
      x: dir < 0 ? 50 : -50,
      opacity: 0
    })
  };

  return (
    <main className="min-h-screen pt-32 pb-24 overflow-hidden">
      <section className="container-x max-w-4xl">
        <motion.div
          className="mb-12 text-center"
          initial={{ opacity: 0, y: 20 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ duration: 0.5, ease: "easeOut" as const }}
        >
          <p className="font-mono text-sm font-semibold tracking-widest text-primary uppercase mb-4">Inzahlungnahme · Bewertung</p>
          <h1 className="font-display text-4xl sm:text-5xl font-semibold tracking-tight mb-4">
            Was ist Ihr Fahrzeug wert?
          </h1>
          <p className="text-lg text-muted-foreground max-w-2xl mx-auto">
            Finden Sie in wenigen Schritten den aktuellen Marktwert Ihres Fahrzeugs heraus. Unverbindlich und transparent.
          </p>
        </motion.div>

        {/* Progress Bar */}
        <div className="mb-12 relative">
          <div className="absolute top-1/2 left-0 w-full h-0.5 bg-border -translate-y-1/2 rounded-full" />
          <motion.div 
            className="absolute top-1/2 left-0 h-0.5 bg-primary -translate-y-1/2 rounded-full transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]"
            style={{ width: `${((step - 1) / 5) * 100}%` }}
          />
          <div className="relative flex justify-between">
            {[1, 2, 3, 4, 5, 6].map((i) => (
              <div 
                key={i} 
                className={cn(
                  'flex items-center justify-center size-8 rounded-full font-mono text-xs font-bold transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] relative z-10',
                  i < step ? 'bg-primary text-primary-foreground scale-100 shadow-glow-primary' : 
                  i === step ? 'bg-background border-2 border-primary text-primary scale-110 shadow-sm' : 
                  'bg-background border-2 border-border text-muted-foreground scale-90'
                )}
              >
                {i < step ? <Check className="size-4" /> : i}
              </div>
            ))}
          </div>
          <div className="flex justify-between mt-4">
            <span className="text-xs font-semibold text-primary uppercase tracking-wider">Start</span>
            <span className="text-xs font-semibold text-muted-foreground uppercase tracking-wider">Ergebnis</span>
          </div>
        </div>

        {/* Wizard Card */}
        <div className="bg-card border border-border rounded-2xl shadow-card overflow-hidden min-h-[var(--layout-hero-md)] flex flex-col relative">
          <div className="flex-1 p-8 sm:p-12 relative overflow-x-hidden">
            <AnimatePresence initial={false} custom={direction} mode="wait">
              <motion.div
                key={step}
                custom={direction}
                variants={variants}
                initial="enter"
                animate="center"
                exit="exit"
                transition={{ duration: 0.4, ease: [0.16, 1, 0.3, 1] as any }}
                className="absolute inset-0 p-8 sm:p-12 h-full flex flex-col"
              >
                {/* STEP 1: Brand */}
                {step === 1 && (
                  <div className="flex-1">
                    <h2 className="text-2xl font-semibold mb-6 flex items-center gap-3">
                      <CarFront className="size-6 text-primary" />
                      Marke wählen
                    </h2>
                    <div className="grid grid-cols-2 sm:grid-cols-4 gap-3">
                      {BRANDS.map(brand => (
                        <button
                          key={brand}
                          onClick={() => {
                            setValue('brand', brand, { shouldValidate: true });
                            // Reset dependent fields
                            setValue('model', '');
                            setTimeout(handleNext, 300);
                          }}
                          className={cn(
                            'p-4 rounded-xl border text-sm font-semibold transition-all min-h-[var(--space-10)]',
                            values.brand === brand
                              ? 'border-primary bg-primary/5 text-primary shadow-sm ring-1 ring-primary/20 scale-[0.98]'
                              : 'border-border bg-card text-foreground hover:border-border-strong hover:bg-muted/50'
                          )}
                        >
                          {brand}
                        </button>
                      ))}
                    </div>
                  </div>
                )}

                {/* STEP 2: Model */}
                {step === 2 && (
                  <div className="flex-1">
                    <h2 className="text-2xl font-semibold mb-6 flex items-center gap-3">
                      <CarFront className="size-6 text-primary" />
                      Modell wählen
                    </h2>
                    <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
                      {currentModels.map(model => (
                        <button
                          key={model}
                          onClick={() => {
                            setValue('model', model, { shouldValidate: true });
                            setTimeout(handleNext, 300);
                          }}
                          className={cn(
                            'flex items-center justify-between p-5 rounded-xl border text-left transition-all min-h-[var(--space-10)]',
                            values.model === model
                              ? 'border-primary bg-primary/5 text-primary shadow-sm ring-1 ring-primary/20 scale-[0.98]'
                              : 'border-border bg-card text-foreground hover:border-border-strong hover:bg-muted/50'
                          )}
                        >
                          <span className="font-semibold">{model}</span>
                          {values.model === model && <Check className="size-5" />}
                        </button>
                      ))}
                    </div>
                  </div>
                )}

                {/* STEP 3: Year & Mileage */}
                {step === 3 && (
                  <div className="flex-1">
                    <h2 className="text-2xl font-semibold mb-8 flex items-center gap-3">
                      <Calendar className="size-6 text-primary" />
                      Alter & Laufleistung
                    </h2>
                    <div className="grid grid-cols-1 sm:grid-cols-2 gap-8">
                      <div className="space-y-3">
                        <label className="text-sm font-semibold text-muted-foreground flex items-center gap-2">
                          <Calendar className="size-4" /> Erstzulassung (Jahr)
                        </label>
                        <Controller
                          name="year"
                          control={control}
                          render={({ field }) => (
                            <div>
                              <input
                                {...field}
                                type="number"
                                placeholder="z.B. 2018"
                                value={field.value || ''}
                                onChange={e => field.onChange(e.target.value ? Number(e.target.value) : undefined)}
                                className={cn(
                                  'w-full bg-card border rounded-xl px-4 py-3.5 text-lg font-mono min-h-[var(--space-10)] transition-colors focus:outline-none focus:ring-2 focus:ring-primary/20',
                                  errors.year ? 'border-destructive focus:border-destructive' : 'border-border focus:border-primary'
                                )}
                              />
                              {errors.year && <p className="text-destructive text-sm mt-1.5">{errors.year.message}</p>}
                            </div>
                          )}
                        />
                      </div>
                      <div className="space-y-3">
                        <label className="text-sm font-semibold text-muted-foreground flex items-center gap-2">
                          <Gauge className="size-4" /> Kilometerstand
                        </label>
                        <Controller
                          name="mileage"
                          control={control}
                          render={({ field }) => (
                            <div>
                              <input
                                {...field}
                                type="number"
                                placeholder="z.B. 45000"
                                value={field.value || ''}
                                onChange={e => field.onChange(e.target.value ? Number(e.target.value) : undefined)}
                                className={cn(
                                  'w-full bg-card border rounded-xl px-4 py-3.5 text-lg font-mono min-h-[var(--space-10)] transition-colors focus:outline-none focus:ring-2 focus:ring-primary/20',
                                  errors.mileage ? 'border-destructive focus:border-destructive' : 'border-border focus:border-primary'
                                )}
                              />
                              {errors.mileage && <p className="text-destructive text-sm mt-1.5">{errors.mileage.message}</p>}
                            </div>
                          )}
                        />
                      </div>
                    </div>
                  </div>
                )}

                {/* STEP 4: Equipment */}
                {step === 4 && (
                  <div className="flex-1">
                    <h2 className="text-2xl font-semibold mb-2 flex items-center gap-3">
                      <Sparkles className="size-6 text-primary" />
                      Sonderausstattung
                    </h2>
                    <p className="text-sm text-muted-foreground mb-6">Wählen Sie alle zutreffenden Merkmale aus.</p>
                    <div className="grid grid-cols-1 sm:grid-cols-2 gap-3">
                      {EQUIPMENT_OPTIONS.map(eq => {
                        const isSelected = values.equipment?.includes(eq);
                        return (
                          <button
                            key={eq}
                            onClick={() => {
                              const curr = values.equipment || [];
                              const next = isSelected ? curr.filter(x => x !== eq) : [...curr, eq];
                              setValue('equipment', next);
                            }}
                            className={cn(
                              'flex items-center gap-3 p-4 rounded-xl border text-left transition-all min-h-[var(--space-10)]',
                              isSelected
                                ? 'border-primary bg-primary/5 text-primary ring-1 ring-primary/20'
                                : 'border-border bg-card text-foreground hover:border-border-strong'
                            )}
                          >
                            <div className={cn(
                              'size-5 rounded border flex items-center justify-center transition-colors',
                              isSelected ? 'bg-primary border-primary text-primary-foreground' : 'border-muted-foreground'
                            )}>
                              {isSelected && <Check className="size-3.5" />}
                            </div>
                            <span className="font-medium text-sm">{eq}</span>
                          </button>
                        );
                      })}
                    </div>
                  </div>
                )}

                {/* STEP 5: Condition */}
                {step === 5 && (
                  <div className="flex-1">
                    <h2 className="text-2xl font-semibold mb-6 flex items-center gap-3">
                      <Wrench className="size-6 text-primary" />
                      Fahrzeugzustand
                    </h2>
                    <div className="space-y-3">
                      {CONDITIONS.map(cond => (
                        <button
                          key={cond.id}
                          onClick={() => setValue('condition', cond.id, { shouldValidate: true })}
                          className={cn(
                            'flex items-center justify-between p-5 rounded-xl border text-left transition-all w-full min-h-[var(--space-10)]',
                            values.condition === cond.id
                              ? 'border-primary bg-primary/5 text-primary shadow-sm ring-1 ring-primary/20 scale-[0.98]'
                              : 'border-border bg-card text-foreground hover:border-border-strong hover:bg-muted/50'
                          )}
                        >
                          <div>
                            <span className="font-semibold block mb-1">{cond.id}</span>
                            <span className={cn('text-xs', values.condition === cond.id ? 'text-primary/80' : 'text-muted-foreground')}>
                              {cond.desc}
                            </span>
                          </div>
                          {values.condition === cond.id && <Check className="size-5 shrink-0" />}
                        </button>
                      ))}
                    </div>
                  </div>
                )}

                {/* STEP 6: Result */}
                {step === 6 && (
                  <div className="flex-1 flex flex-col items-center justify-center text-center">
                    <motion.div
                      initial={{ scale: 0.8, opacity: 0 }}
                      animate={{ scale: 1, opacity: 1 }}
                      transition={{ delay: 0.2, type: "spring", stiffness: 200, damping: 20 }}
                      className="size-20 bg-primary/10 text-primary rounded-full flex items-center justify-center mb-6"
                    >
                      <CircleDollarSign className="size-10" />
                    </motion.div>
                    
                    <motion.h3 
                      initial={{ y: 20, opacity: 0 }}
                      animate={{ y: 0, opacity: 1 }}
                      transition={{ delay: 0.3 }}
                      className="text-muted-foreground font-semibold uppercase tracking-widest text-sm mb-4"
                    >
                      Geschätzter Ankaufswert
                    </motion.h3>

                    <motion.div
                      initial={{ y: 20, opacity: 0 }}
                      animate={{ y: 0, opacity: 1 }}
                      transition={{ delay: 0.4 }}
                      className="font-mono text-5xl sm:text-6xl font-bold tracking-tighter text-foreground mb-4 tabular-nums"
                    >
                      € 18.450 <span className="text-muted-foreground font-normal">–</span> 21.200
                    </motion.div>

                    <motion.p
                      initial={{ y: 20, opacity: 0 }}
                      animate={{ y: 0, opacity: 1 }}
                      transition={{ delay: 0.5 }}
                      className="text-muted-foreground max-w-md mx-auto mb-10 text-sm"
                    >
                      Dieser Wert basiert auf aktuellen Marktdaten für einen {values.brand} {values.model} (Bj. {values.year}) mit {values.mileage} km.
                    </motion.p>

                    <motion.div
                      initial={{ y: 20, opacity: 0 }}
                      animate={{ y: 0, opacity: 1 }}
                      transition={{ delay: 0.6 }}
                      className="grid grid-cols-1 sm:grid-cols-3 gap-4 w-full"
                    >
                      <button className="flex flex-col items-center justify-center gap-3 p-5 rounded-xl border border-border bg-card hover:border-border-strong transition-all hover:bg-muted/30">
                        <BarChart3 className="size-6 text-muted-foreground" />
                        <span className="font-semibold text-sm">Direkt verkaufen</span>
                      </button>
                      <button className="flex flex-col items-center justify-center gap-3 p-5 rounded-xl border border-primary bg-primary text-primary-foreground shadow-glow-primary transition-all hover:opacity-90 scale-105 z-10">
                        <Repeat className="size-6" />
                        <span className="font-semibold text-sm">Inzahlung geben</span>
                      </button>
                      <button className="flex flex-col items-center justify-center gap-3 p-5 rounded-xl border border-border bg-card hover:border-border-strong transition-all hover:bg-muted/30">
                        <Info className="size-6 text-muted-foreground" />
                        <span className="font-semibold text-sm">Inserieren</span>
                      </button>
                    </motion.div>
                  </div>
                )}
              </motion.div>
            </AnimatePresence>
          </div>

          {/* Navigation Footer */}
          {step < 6 && (
            <div className="border-t border-border bg-muted/20 p-6 sm:px-12 flex items-center justify-between">
              <button
                onClick={handleBack}
                disabled={step === 1}
                className={cn(
                  'flex items-center gap-2 font-semibold text-sm transition-all min-h-[var(--space-10)]',
                  step === 1 ? 'opacity-0 pointer-events-none' : 'text-muted-foreground hover:text-foreground'
                )}
              >
                <ArrowLeft className="size-4" />
                Zurück
              </button>
              
              <button
                onClick={handleNext}
                disabled={!isStepValid()}
                className="flex min-h-[var(--space-10)] items-center gap-2 rounded-xl bg-foreground px-6 py-2.5 text-sm font-semibold text-background transition-all disabled:opacity-50 disabled:cursor-not-allowed hover:bg-foreground/90 active:scale-[0.98]"
              >
                Weiter
                <ArrowRight className="size-4" />
              </button>
            </div>
          )}
        </div>
      </section>
    </main>
  );
}
'use client';

import { useState } from 'react';
import { motion } from 'framer-motion';
import {
  Phone,
  Mail,
  MapPin,
  Send,
  CheckCircle2,
  Clock,
} from 'lucide-react';
import { cn } from '@/lib/cn';

/* ------------------------------------------------------------------ */
/*  Data                                                               */
/* ------------------------------------------------------------------ */

interface ContactPill {
  icon: React.ElementType;
  label: string;
  value: string;
  href: string;
}

const PILLS: ContactPill[] = [
  { icon: Phone, label: 'Anrufen', value: '+49 6441 22 88-0', href: 'tel:+4964412288' },
  { icon: Mail, label: 'Schreiben', value: 'hallo@apex-motors.de', href: 'mailto:hallo@apex-motors.de' },
  { icon: MapPin, label: 'Besuchen', value: 'Hermann-Löns-Str. 14', href: '#karte' },
];

const BETREFF_OPTIONS = [
  'Allgemeine Anfrage',
  'Fahrzeuganfrage',
  'Probefahrt',
  'Service',
  'Finanzierung',
  'Sonstiges',
] as const;

interface OpeningHour {
  day: string;
  time: string;
  closed?: boolean;
}

const HOURS: OpeningHour[] = [
  { day: 'Montag – Freitag', time: '08:00 – 18:00' },
  { day: 'Samstag', time: '09:00 – 17:00' },
  { day: 'Sonntag', time: 'Geschlossen', closed: true },
];

/* ------------------------------------------------------------------ */
/*  Animations                                                         */
/* ------------------------------------------------------------------ */

const fadeUp = {
  hidden: { opacity: 0, y: 28 },
  visible: {
    opacity: 1,
    y: 0,
    transition: { duration: 0.6, ease: [0.16, 1, 0.3, 1] as const },
  },
};

const stagger = {
  hidden: {},
  visible: { transition: { staggerChildren: 0.1 } },
};

/* ------------------------------------------------------------------ */
/*  Page                                                               */
/* ------------------------------------------------------------------ */

export default function KontaktPage() {
  const [betreff, setBetreff] = useState('Allgemeine Anfrage');
  const [name, setName] = useState('');
  const [telefon, setTelefon] = useState('');
  const [email, setEmail] = useState('');
  const [nachricht, setNachricht] = useState('');
  const [datenschutz, setDatenschutz] = useState(false);
  const [submitted, setSubmitted] = useState(false);

  function handleSubmit(e: React.FormEvent<HTMLFormElement>) {
    e.preventDefault();
    setSubmitted(true);
    setTimeout(() => setSubmitted(false), 5000);
  }

  return (
    <main className="min-h-screen">
      {/* ============================================================ */}
      {/*  HERO                                                        */}
      {/* ============================================================ */}
      <section className="relative overflow-hidden bg-background">
        <div className="hero-img-bg" />
        <div className="container-x section-y relative z-10 flex flex-col items-start gap-6 pt-32 pb-20 lg:pt-40 lg:pb-28">
          <motion.p
            initial={{ opacity: 0, y: 12 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.5, ease: "easeOut" as const }}
            className="eyebrow"
          >
            {'// Kontakt'}
          </motion.p>

          <motion.h1
            initial={{ opacity: 0, y: 24 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.6, delay: 0.1, ease: [0.16, 1, 0.3, 1] as const }}
            className="text-display max-w-3xl"
          >
            Sprechen Sie mit uns.
          </motion.h1>
        </div>
      </section>

      {/* ============================================================ */}
      {/*  CONTACT PILLS                                               */}
      {/* ============================================================ */}
      <section className="border-y border-border bg-card">
        <motion.div
          variants={stagger}
          initial="hidden"
          whileInView="visible"
          viewport={{ once: true, margin: '-10%' }}
          className="container-x grid grid-cols-1 sm:grid-cols-3 divide-y sm:divide-y-0 sm:divide-x divide-border"
        >
          {PILLS.map((pill) => {
            const Icon = pill.icon;
            return (
              <motion.a
                key={pill.label}
                variants={fadeUp}
                href={pill.href}
                className="flex items-center gap-4 py-6 px-4 hover:bg-muted/40 transition-colors group min-h-[var(--space-10)]"
              >
                <div className="w-11 h-11 rounded-lg bg-primary/10 flex items-center justify-center text-primary shrink-0 group-hover:bg-primary/15 transition-colors">
                  <Icon size={20} />
                </div>
                <div>
                  <p className="text-sm text-muted-foreground">{pill.label}</p>
                  <p className={cn(
                    'font-medium text-foreground',
                    pill.icon === Phone && 'font-mono tabular-nums'
                  )}>
                    {pill.value}
                  </p>
                </div>
              </motion.a>
            );
          })}
        </motion.div>
      </section>

      {/* ============================================================ */}
      {/*  MAP PLACEHOLDER + HOURS                                     */}
      {/* ============================================================ */}
      <section className="section-y bg-background" id="karte">
        <div className="container-x grid grid-cols-1 lg:grid-cols-3 gap-8">
          {/* Stylized map */}
          <motion.div
            initial={{ opacity: 0, y: 24 }}
            whileInView={{ opacity: 1, y: 0 }}
            viewport={{ once: true, margin: '-10%' }}
            transition={{ duration: 0.7, ease: [0.16, 1, 0.3, 1] as const }}
            className="lg:col-span-2 relative rounded-xl overflow-hidden bg-foreground min-h-[var(--layout-sidebar-sm)] lg:min-h-[var(--layout-hero-sm)]"
          >
            {/* Grid pattern */}
            <div
              className="absolute inset-0"
              style={{
                backgroundImage:
                  'linear-gradient(color-mix(in srgb, var(--color-off-white-50) 6%, transparent) calc(var(--space-1) * 0.25), transparent calc(var(--space-1) * 0.25)), linear-gradient(90deg, color-mix(in srgb, var(--color-off-white-50) 6%, transparent) calc(var(--space-1) * 0.25), transparent calc(var(--space-1) * 0.25))',
                backgroundSize: 'calc(var(--space-1) * 10) calc(var(--space-1) * 10)',
              }}
            />

            {/* Red pin */}
            <div className="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 flex flex-col items-center">
              <div className="w-5 h-5 rounded-full bg-primary shadow-glow-primary" />
              <div className="w-1 h-6 bg-primary/60 rounded-b-full" />
              <div className="mt-3 px-4 py-2 rounded-lg bg-background/95 backdrop-blur-sm text-sm font-medium shadow-modal whitespace-nowrap">
                <span className="text-primary font-bold">Apex Motors</span>
                <br />
                <span className="text-muted-foreground text-xs">Hermann-Löns-Str. 14 · 35578 Wetzlar</span>
              </div>
            </div>

            {/* Subtle radial glow */}
            <div className="absolute inset-0 bg-[radial-gradient(50%_50%_at_50%_50%,color-mix(in_srgb,var(--color-primary)_8%,transparent),transparent)]" />
          </motion.div>

          {/* Opening hours */}
          <motion.div
            initial={{ opacity: 0, y: 24 }}
            whileInView={{ opacity: 1, y: 0 }}
            viewport={{ once: true, margin: '-10%' }}
            transition={{ duration: 0.7, delay: 0.15, ease: [0.16, 1, 0.3, 1] as const }}
            className="card p-6 md:p-8 self-start"
          >
            <div className="flex items-center gap-2 mb-6">
              <Clock size={18} className="text-primary" />
              <h3 className="text-h4">Öffnungszeiten</h3>
            </div>

            <table className="w-full">
              <tbody>
                {HOURS.map((h) => (
                  <tr key={h.day} className="border-b border-border last:border-0">
                    <td className="py-3 text-sm text-muted-foreground">{h.day}</td>
                    <td className={cn(
                      'py-3 text-sm text-right font-mono tabular-nums',
                      h.closed ? 'text-muted-foreground' : 'text-foreground font-medium'
                    )}>
                      {h.time}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>

            <div className="mt-6 pt-4 border-t border-border">
              <p className="text-xs text-muted-foreground">
                Feiertage abweichend. Notdienst rund um die Uhr unter{' '}
                <a href="tel:+4964410000" className="text-primary font-mono tabular-nums hover:underline">
                  +49 6441 0000
                </a>
              </p>
            </div>
          </motion.div>
        </div>
      </section>

      {/* ============================================================ */}
      {/*  CONTACT FORM                                                */}
      {/* ============================================================ */}
      <section className="section-y bg-muted/40">
        <div className="container-x max-w-3xl">
          <motion.div
            initial={{ opacity: 0, y: 20 }}
            whileInView={{ opacity: 1, y: 0 }}
            viewport={{ once: true, margin: '-10%' }}
            transition={{ duration: 0.6, ease: [0.16, 1, 0.3, 1] as const }}
            className="mb-10"
          >
            <p className="eyebrow mb-3">{'// Nachricht'}</p>
            <h2 className="text-h1">Schreiben Sie uns</h2>
          </motion.div>

          <motion.form
            initial={{ opacity: 0, y: 24 }}
            whileInView={{ opacity: 1, y: 0 }}
            viewport={{ once: true, margin: '-5%' }}
            transition={{ duration: 0.6, delay: 0.1, ease: [0.16, 1, 0.3, 1] as const }}
            onSubmit={handleSubmit}
            className="card p-6 md:p-8 space-y-6"
          >
            {/* Betreff */}
            <div>
              <label htmlFor="ct-betreff" className="text-sm font-medium mb-1.5 block">
                Betreff
              </label>
              <select
                id="ct-betreff"
                value={betreff}
                onChange={(e) => setBetreff(e.target.value)}
                className="select-field"
              >
                {BETREFF_OPTIONS.map((opt) => (
                  <option key={opt} value={opt}>
                    {opt}
                  </option>
                ))}
              </select>
            </div>

            {/* Name + Telefon */}
            <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label htmlFor="ct-name" className="text-sm font-medium mb-1.5 block">
                  Name
                </label>
                <input
                  id="ct-name"
                  type="text"
                  value={name}
                  onChange={(e) => setName(e.target.value)}
                  placeholder="Ihr vollständiger Name"
                  className="input"
                  required
                />
              </div>
              <div>
                <label htmlFor="ct-telefon" className="text-sm font-medium mb-1.5 block">
                  Telefon
                </label>
                <input
                  id="ct-telefon"
                  type="tel"
                  value={telefon}
                  onChange={(e) => setTelefon(e.target.value)}
                  placeholder="+49 ..."
                  className="input font-mono tabular-nums"
                />
              </div>
            </div>

            {/* E-Mail */}
            <div>
              <label htmlFor="ct-email" className="text-sm font-medium mb-1.5 block">
                E-Mail
              </label>
              <input
                id="ct-email"
                type="email"
                value={email}
                onChange={(e) => setEmail(e.target.value)}
                placeholder="ihre@email.de"
                className="input"
                required
              />
            </div>

            {/* Nachricht */}
            <div>
              <label htmlFor="ct-nachricht" className="text-sm font-medium mb-1.5 block">
                Nachricht
              </label>
              <textarea
                id="ct-nachricht"
                value={nachricht}
                onChange={(e) => setNachricht(e.target.value)}
                placeholder="Wie können wir Ihnen helfen?"
                className="textarea"
                rows={5}
                required
              />
            </div>

            {/* Datenschutz */}
            <label className="flex items-start gap-3 cursor-pointer group">
              <input
                type="checkbox"
                checked={datenschutz}
                onChange={(e) => setDatenschutz(e.target.checked)}
                className="checkbox mt-0.5"
                required
              />
              <span className="text-sm text-muted-foreground leading-relaxed">
                Ich habe die{' '}
                <span className="text-primary hover:underline cursor-pointer">
                  Datenschutzerklärung
                </span>{' '}
                gelesen und bin mit der Verarbeitung meiner Daten einverstanden.
              </span>
            </label>

            {/* Submit */}
            <button
              type="submit"
              className="btn btn-primary btn-lg w-full gap-2 min-h-[var(--space-10)]"
            >
              <Send size={16} />
              Nachricht senden
            </button>

            {/* Toast */}
            {submitted && (
              <motion.div
                initial={{ opacity: 0, y: 8 }}
                animate={{ opacity: 1, y: 0 }}
                exit={{ opacity: 0 }}
                className="flex items-center gap-3 rounded-lg bg-success/10 border border-success/30 text-success px-4 py-3 text-sm font-medium"
              >
                <CheckCircle2 size={18} />
                Ihre Nachricht wurde gesendet. Wir melden uns innerhalb von 24 Stunden.
              </motion.div>
            )}
          </motion.form>
        </div>
      </section>
    </main>
  );
}
'use client';

